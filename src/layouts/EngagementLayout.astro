---
import BaseLayout from './BaseLayout.astro';
import PhotoStack from '../components/PhotoStack.astro';
import { serviceSchema } from '../lib/schema';
import { CTA } from '../consts';

// Shared layout for Services sub-pages. Header is a forest color block with a
// FEATHERED (blended-edge) photo — no harsh full-bleed image lines. Premium,
// consistent. Page content comes through the default slot.
interface Props {
  title: string;
  eyebrow: string;
  lede: string;
  heroImage: string;
  heroRatio?: string;
  description: string;
}
const { title, eyebrow, lede, heroImage, heroRatio = '4 / 5', description } = Astro.props;
---
<BaseLayout title={title} description={description} schemas={[serviceSchema()]}>
  <!-- HEADER — forest block + feathered photo -->
  <section class="ep-hero section--forest">
    <div class="container ep-hero__grid">
      <div class="ep-hero__copy" data-reveal="left">
        <p class="ep-back"><a href="/services">← All engagements</a></p>
        <p class="subhead">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="ep-lede">{lede}</p>
        <a class="button" href={CTA.calendly}>Book a call</a>
      </div>
      <PhotoStack src={heroImage} alt="Laura Seelinger" ratio={heroRatio} reveal delay="1" />
    </div>
  </section>

  <div class="ep-body">
    <slot />
  </div>

  <!-- CLOSING CTA (forest) -->
  <section class="band section--forest">
    <div class="container measure measure--center" data-reveal="scale">
      <h2>Let’s talk about your brand</h2>
      <p>Twenty minutes, no pitch deck. We’ll figure out if this is the right fit.</p>
      <a class="button" href={CTA.calendly}>Book a call</a>
    </div>
  </section>
</BaseLayout>

<style>
  .ep-hero { padding-block: var(--space-6); }
  .ep-hero__grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-5);
    align-items: center;
  }
  .ep-hero__copy { max-width: 56ch; }
  .ep-back { margin-bottom: var(--space-2); }
  .ep-back a { color: var(--cream); opacity: 0.85; text-decoration: none; font-size: var(--text-sm); }
  .ep-back a:hover { opacity: 1; }
  .ep-hero h1 { font-size: clamp(2.4rem, 1.6rem + 4vw, 4.5rem); margin-block: var(--space-1) var(--space-2); }
  .ep-lede { font-size: var(--text-lg); max-width: 50ch; margin-bottom: var(--space-3); }
  /* No padding here — each slotted .band brings its own (avoids triple-stacking). */
  .ep-body { padding-block: 0; }

  @media (max-width: 760px) {
    .ep-hero__grid { grid-template-columns: 1fr; }
    .ep-hero :global(.pstack) { order: -1; width: min(320px, 80%); }
  }
</style>
