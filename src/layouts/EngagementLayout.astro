---
import BaseLayout from './BaseLayout.astro';
import { serviceSchema } from '../lib/schema';
import { CTA } from '../consts';

// Shared layout for Services sub-pages (engagement types). Full-bleed header
// photo with the title over it (image-forward), premium tone, consistent
// section rhythm. Page-specific content comes through the default slot.
interface Props {
  title: string;
  eyebrow: string;
  lede: string;
  heroImage: string;
  description: string;
}
const { title, eyebrow, lede, heroImage, description } = Astro.props;
---
<BaseLayout title={title} description={description} schemas={[serviceSchema()]}>
  <!-- HEADER — full-bleed photo + overlay -->
  <section class="ep-hero media-overlay media-overlay--hero">
    <img class="bg" src={heroImage} alt="" aria-hidden="true" />
    <div class="container">
      <p class="ep-back"><a href="/services">← All engagements</a></p>
      <p class="subhead">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="ep-lede">{lede}</p>
      <a class="button" href={CTA.calendly}>Book a call</a>
    </div>
  </section>

  <div class="ep-body">
    <slot />
  </div>

  <!-- CLOSING CTA (forest) -->
  <section class="band section--forest">
    <div class="container measure measure--center" data-reveal="scale">
      <h2>Let’s talk about your brand</h2>
      <p>Twenty minutes, no pitch deck. We’ll figure out if this is the right fit.</p>
      <a class="button" href={CTA.calendly}>Book a call</a>
    </div>
  </section>
</BaseLayout>

<style>
  .ep-hero { display: flex; align-items: center; min-height: 70vh; padding-block: var(--space-6); }
  .ep-hero .container { max-width: 820px; }
  .ep-back { margin-bottom: var(--space-2); }
  .ep-back a { color: var(--cream); opacity: 0.85; text-decoration: none; font-size: var(--text-sm); }
  .ep-back a:hover { opacity: 1; }
  .ep-hero h1 { font-size: clamp(2.4rem, 1.6rem + 4vw, 4.5rem); margin-block: var(--space-1) var(--space-2); }
  .ep-lede { font-size: var(--text-lg); max-width: 50ch; margin-bottom: var(--space-3); }
  .ep-body { padding-block: var(--space-6); }
  .ep-body :global(.container) { }
</style>
