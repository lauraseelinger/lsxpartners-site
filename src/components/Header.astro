---
import { SITE, NAV, CTA, ENGAGEMENTS } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${SITE.name} home`}>
      <img src="/brand/logo/horizontal-rust.svg" alt={SITE.name} height="34" />
    </a>

    <button type="button" class="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Open menu">
      <svg class="nav-toggle__open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <svg class="nav-toggle__close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
    </button>

    <nav id="primary-nav" aria-label="Primary">
      <ul>
        {
          NAV.map((n) =>
            n.href === '/services' ? (
              <li class="has-dropdown">
                <a href={n.href} aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
                <button type="button" class="dd-toggle" aria-expanded="false" aria-label="Show services menu">▾</button>
                <ul class="dropdown">
                  <li><a href="/services" class="dropdown__all">All services</a></li>
                  {ENGAGEMENTS.map((e) => (
                    <li><a href={`/services/${e.slug}`}>{e.name}</a></li>
                  ))}
                </ul>
              </li>
            ) : (
              <li>
                <a href={n.href} aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
              </li>
            )
          )
        }
        <li class="nav-cta"><a class="button" href={CTA.calendly}>Book a call</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-2);
  }
  .site-header__brand { display: inline-flex; align-items: center; }
  .site-header__brand img { display: block; }
  nav > ul {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    text-decoration: none;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  nav a[aria-current='page'] { color: var(--color-accent); }
  nav a:not(.button):hover { color: var(--color-text); }
  nav a.button { color: var(--cream); }
  nav a.button:hover { color: var(--cream); }

  /* Hamburger — hidden on desktop */
  .nav-toggle {
    display: none;
    align-items: center; justify-content: center;
    width: 2.75rem; height: 2.75rem; padding: 0;
    background: transparent; border: 0; color: var(--brown); cursor: pointer;
  }
  .nav-toggle svg { width: 1.6rem; height: 1.6rem; }
  .nav-toggle__close { display: none; }

  /* Services dropdown */
  .has-dropdown { position: relative; }
  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 230px;
    margin-top: 0.5rem;
    padding: var(--space-1);
    list-style: none;
    background: var(--cream);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: var(--shadow-soft);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    z-index: 60;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown li { margin: 0; }
  .dropdown a {
    display: block;
    padding: 0.55rem 0.7rem;
    border-radius: 8px;
    font-size: var(--text-sm);
  }
  .dropdown a:hover { background: var(--cream-deep); color: var(--brown); }
  .dropdown__all { font-weight: 700; color: var(--brown); }
  .dropdown li:has(.dropdown__all) { border-bottom: 1px solid var(--color-border); margin-bottom: 0.2rem; padding-bottom: 0.2rem; }

  /* caret toggle — desktop uses hover, so it's hidden there */
  .dd-toggle { display: none; }

  /* ---- Mobile: hamburger reveals a stacked panel ---- */
  @media (max-width: 900px) {
    .nav-toggle { display: inline-flex; }
    .site-header.is-open .nav-toggle__open { display: none; }
    .site-header.is-open .nav-toggle__close { display: block; }

    nav#primary-nav {
      position: absolute;
      top: 100%; left: 0; right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-soft);
      max-height: calc(100vh - 100%);
      overflow-y: auto;
      display: none;
    }
    .site-header.is-open nav#primary-nav { display: block; }

    nav > ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-1) 0 var(--space-3);
    }
    nav > ul > li { width: 100%; }
    nav > ul > li > a:not(.button) {
      display: block;
      padding: 0.85rem var(--space-3);
      font-size: var(--text-lg);
    }

    /* Services row: label + caret on one line, submenu collapses below */
    .has-dropdown { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; }
    .has-dropdown > a { flex: 1; }
    .dd-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      width: 2.75rem; height: 2.75rem; margin-right: var(--space-2); padding: 0;
      background: transparent; border: 0; color: var(--color-text-muted);
      font-size: 1.1rem; line-height: 1; cursor: pointer; transition: transform 0.15s ease;
    }
    .has-dropdown.is-open .dd-toggle { transform: rotate(180deg); color: var(--color-accent); }
    .dropdown {
      position: static; opacity: 1; visibility: visible; transform: none;
      box-shadow: none; border: 0; background: var(--cream-deep); min-width: 0;
      margin: 0; padding: 0; flex-basis: 100%;
      display: none;
    }
    .has-dropdown.is-open .dropdown { display: block; }
    .dropdown a { padding: 0.7rem var(--space-3) 0.7rem var(--space-4); border-radius: 0; font-size: var(--text-base); }
    .dropdown__all { font-weight: 700; }
    .dropdown li:has(.dropdown__all) { border-bottom: 1px solid var(--color-border); margin-bottom: 0; padding-bottom: 0; }

    /* Book a call — full-width button in the panel */
    .nav-cta { padding: var(--space-2) var(--space-3) 0; }
    .nav-cta .button { display: block; text-align: center; }
  }
</style>

<script>
  // Hamburger toggles the whole mobile panel.
  const header = document.querySelector('.site-header');
  const toggle = header?.querySelector('.nav-toggle') as HTMLButtonElement | null;
  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });

  // On mobile the whole Services row expands the submenu (caret OR label),
  // instead of navigating to /services — "All services" inside still links there.
  function toggleServices(li: Element | null, caret: Element | null) {
    const open = li?.classList.toggle('is-open');
    caret?.setAttribute('aria-expanded', open ? 'true' : 'false');
  }
  document.querySelectorAll('.dd-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      toggleServices(btn.closest('.has-dropdown'), btn);
    });
  });
  document.querySelectorAll('.has-dropdown > a').forEach((link) => {
    link.addEventListener('click', (e) => {
      const caret = link.parentElement?.querySelector('.dd-toggle') as HTMLElement | null;
      // caret is only visible in mobile mode; if so, expand rather than navigate
      if (caret && caret.offsetParent !== null) {
        e.preventDefault();
        toggleServices(link.closest('.has-dropdown'), caret);
      }
    });
  });

  // Close the panel when the viewport grows back to desktop.
  window.addEventListener('resize', () => {
    if (window.innerWidth > 900 && header?.classList.contains('is-open')) {
      header.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
    }
  });
</script>
