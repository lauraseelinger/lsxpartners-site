---
import { SITE, NAV, CTA, ENGAGEMENTS } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${SITE.name} home`}>
      <img src="/brand/logo/horizontal-rust.svg" alt={SITE.name} height="34" />
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          NAV.map((n) =>
            n.href === '/services' ? (
              <li class="has-dropdown">
                <a href={n.href} aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
                <button type="button" class="dd-toggle" aria-expanded="false" aria-label="Show services menu">▾</button>
                <ul class="dropdown">
                  <li><a href="/services" class="dropdown__all">All services</a></li>
                  {ENGAGEMENTS.map((e) => (
                    <li><a href={`/services/${e.slug}`}>{e.name}</a></li>
                  ))}
                </ul>
              </li>
            ) : (
              <li>
                <a href={n.href} aria-current={isActive(n.href) ? 'page' : undefined}>{n.label}</a>
              </li>
            )
          )
        }
        <li><a class="button" href={CTA.calendly}>Book a call</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-2);
  }
  .site-header__brand { display: inline-flex; align-items: center; }
  .site-header__brand img { display: block; }
  nav > ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    text-decoration: none;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  nav a[aria-current='page'] { color: var(--color-accent); }
  nav a:not(.button):hover { color: var(--color-text); }
  nav a.button { color: var(--cream); }
  nav a.button:hover { color: var(--cream); }

  /* Services dropdown */
  .has-dropdown { position: relative; }
  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 230px;
    margin-top: 0.5rem;
    padding: var(--space-1);
    list-style: none;
    background: var(--cream);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: var(--shadow-soft);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    z-index: 60;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown li { margin: 0; }
  .dropdown a {
    display: block;
    padding: 0.55rem 0.7rem;
    border-radius: 8px;
    font-size: var(--text-sm);
  }
  .dropdown a:hover { background: var(--cream-deep); color: var(--brown); }
  .dropdown__all { font-weight: 700; color: var(--brown); }
  .dropdown li:has(.dropdown__all) { border-bottom: 1px solid var(--color-border); margin-bottom: 0.2rem; padding-bottom: 0.2rem; }

  /* caret toggle — desktop uses hover, so it's hidden there */
  .dd-toggle { display: none; }

  /* On small screens the submenu is collapsed and opens on a caret tap. */
  @media (max-width: 760px) {
    .has-dropdown { display: flex; flex-wrap: wrap; align-items: center; }
    .dd-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      margin-left: 0.4rem; width: 1.8rem; height: 1.8rem; padding: 0;
      background: transparent; border: 0; color: var(--color-text-muted);
      font-size: 1rem; line-height: 1; cursor: pointer; transition: transform 0.15s ease;
    }
    .has-dropdown.is-open .dd-toggle { transform: rotate(180deg); color: var(--color-accent); }
    .dropdown {
      position: static; opacity: 1; visibility: visible; transform: none;
      box-shadow: none; border: 0; background: transparent; min-width: 0;
      margin: 0; padding: 0 0 0 var(--space-2); flex-basis: 100%;
      display: none;
    }
    .has-dropdown.is-open .dropdown { display: block; }
    .dropdown__all { font-weight: 600; }
    .dropdown li:has(.dropdown__all) { border-bottom: 0; margin-bottom: 0; padding-bottom: 0; }
  }
</style>

<script>
  // Mobile: caret toggles the Services submenu open/closed.
  document.querySelectorAll('.dd-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const li = btn.closest('.has-dropdown');
      const open = li?.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });
</script>
