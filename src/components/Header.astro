---
import { SITE, NAV, CTA } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${SITE.name} home`}>
      <img src="/brand/logo/horizontal-rust.svg" alt={SITE.name} height="34" />
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          NAV.filter((n) => n.href !== '/').map((n) => (
            <li>
              <a href={n.href} aria-current={isActive(n.href) ? 'page' : undefined}>
                {n.label}
              </a>
            </li>
          ))
        }
        <li><a class="button" href={CTA.calendly}>Book a call</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-2);
  }
  .site-header__brand { display: inline-flex; align-items: center; }
  .site-header__brand img { display: block; }
  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    text-decoration: none;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  nav a[aria-current='page'] { color: var(--color-accent); }
  nav a:not(.button):hover { color: var(--color-text); }
  /* Keep the CTA button's own colors (scoped nav a would otherwise win) */
  nav a.button { color: var(--cream); }
  nav a.button:hover { color: var(--cream); }
</style>
