---
// The shift from keyword search to natural-language AI prompts, shown across a
// few industries. The same person types keywords into Google but describes a
// whole situation to AI — only a few words point at the category (highlighted).
const examples = [
  {
    tag: 'ecommerce',
    google: 'running shoes for knee pain',
    ai: 'ok so i keep getting <mark>knee pain</mark> after my runs and i just signed up for my first <mark>half marathon</mark>, mostly training on <mark>pavement</mark> — what <mark>running shoes</mark> actually won’t wreck my joints?',
  },
  {
    tag: 'medtech',
    google: 'best continuous glucose monitor',
    ai: 'my dad was just diagnosed <mark>type 2 diabetic</mark> and he’s not great with tech — is there a <mark>glucose monitor</mark> that skips the <mark>finger pricks</mark> and just shows readings on his <mark>phone</mark>?',
  },
  {
    tag: 'home & hardware',
    google: 'best smart lock for front door',
    ai: 'we just renovated and i want a <mark>front door lock</mark> that works with <mark>our phones</mark>, but my husband keeps getting locked out — something with a <mark>keypad</mark> the kids can use too, that doesn’t look cheap?',
  },
];
---
<div class="qc">
  <div class="qc__viewport">
    <button type="button" class="qc__nav" data-dir="-1" aria-label="Previous example">‹</button>
    <div class="qc__slides">
    {examples.map((ex, i) => (
      <div class:list={['qc__slide', i === 0 && 'is-active']} data-i={i}>
        <span class="qc__cat">{ex.tag}</span>
        <div class="qc__side">
          <span class="qc__tag">the old way · Google</span>
          <div class="qc__bar qc__bar--g">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="qc__icon"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><line x1="16" y1="16" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <span>{ex.google}</span>
          </div>
        </div>
        <div class="qc__side">
          <span class="qc__tag">how they search now · AI</span>
          <div class="qc__bar qc__bar--ai">
            <p class="qc__prompt" set:html={ex.ai}></p>
            <span class="qc__send" aria-hidden="true">➤</span>
          </div>
        </div>
      </div>
    ))}
    </div>
    <button type="button" class="qc__nav" data-dir="1" aria-label="Next example">›</button>
  </div>

  <p class="qc__cap">
    Nobody types keywords into AI. They describe a whole situation — and only a few
    words point at your category. That’s why a keyword tool misses it, and why the
    audit listens for the <em>situations</em> your buyers describe, not the terms they type.
  </p>

  <div class="qc__dots" role="tablist" aria-label="Examples">
    {examples.map((ex, i) => (
      <button type="button" class:list={[i === 0 && 'is-active']} data-i={i} aria-label={ex.tag}></button>
    ))}
  </div>
</div>

<style>
  .qc { max-width: 980px; margin-inline: auto; }
  .qc__viewport { display: flex; align-items: center; gap: var(--space-2); }
  .qc__slides { position: relative; flex: 1; min-width: 0; }
  .qc__nav { flex: none; width: 2.8rem; height: 2.8rem; border-radius: 50%; border: 2px solid var(--brown); background: var(--cream); color: var(--brown); font-size: 1.5rem; line-height: 1; cursor: pointer; transition: background 0.15s, color 0.15s; }
  .qc__nav:hover { background: var(--rust); color: var(--cream); border-color: var(--rust); }
  .qc__slide { display: none; }
  .qc__slide.is-active { display: grid; gap: var(--space-3); }
  .qc__cat { font-family: var(--font-sub); font-weight: 800; font-style: italic; color: var(--rust); font-size: var(--text-sm); }
  .qc__tag { display: inline-block; font-weight: 600; color: var(--olive); font-size: 0.78rem; margin-bottom: 0.35rem; }
  .qc__bar {
    display: flex; align-items: center; gap: var(--space-2);
    background: var(--cream); border: 2px solid var(--brown);
    border-radius: 999px; padding: var(--space-2) var(--space-3); box-shadow: var(--shadow-card);
  }
  .qc__bar--g { color: var(--color-text-muted); }
  .qc__bar--g span { color: var(--brown); }
  .qc__icon { width: 1.2rem; height: 1.2rem; flex: none; }
  .qc__bar--ai { border-radius: 22px; align-items: flex-start; padding: var(--space-3); }
  .qc__prompt { margin: 0; flex: 1; line-height: 1.55; color: var(--brown); font-size: var(--text-lg); }
  .qc__prompt :global(mark) { background: color-mix(in srgb, var(--amber) 55%, var(--cream)); color: var(--brown); padding: 0 0.15em; border-radius: 4px; font-weight: 600; }
  .qc__send { flex: none; display: grid; place-items: center; width: 2rem; height: 2rem; border-radius: 50%; background: var(--rust); color: var(--cream); font-size: 0.9rem; }
  .qc__cap { font-size: var(--text-sm); color: var(--color-text-muted); max-width: 60ch; margin: var(--space-3) 0 var(--space-2); }
  .qc__dots { display: flex; gap: 0.5rem; }
  .qc__dots button { width: 12px; height: 12px; border-radius: 50%; border: 0; cursor: pointer; background: var(--color-border); padding: 0; }
  .qc__dots button.is-active { background: var(--rust); }
</style>

<script>
  document.querySelectorAll('.qc').forEach((qc) => {
    const slides = qc.querySelectorAll('.qc__slide');
    const dots = qc.querySelectorAll('.qc__dots button');
    let idx = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    const show = (i: number) => {
      idx = i;
      slides.forEach((s, j) => s.classList.toggle('is-active', j === i));
      dots.forEach((d, j) => d.classList.toggle('is-active', j === i));
    };
    const start = () => { timer = setInterval(() => show((idx + 1) % slides.length), 5500); };
    const restart = () => { if (timer) clearInterval(timer); start(); };
    dots.forEach((d, i) => d.addEventListener('click', () => { show(i); restart(); }));
    qc.querySelectorAll('.qc__nav').forEach((n) =>
      n.addEventListener('click', () => { show((idx + Number(n.getAttribute('data-dir')) + slides.length) % slides.length); restart(); })
    );
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) start();
  });
</script>
