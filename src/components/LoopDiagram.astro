---
// The AI Intelligence Loop — interactive. The loop visual sits on the left;
// hovering (or tapping/focusing) a stage reveals its explanation on the right.
// Desktop: 4 nodes around a ring. Mobile: ring stacks above the panel; tap a node.
const stages = [
  {
    t: 'Audience intelligence',
    b: 'It begins with listening in the right places — where your buyers talk when no one’s selling to them. The craft is knowing which signals actually matter, separating them from a lot of noise, and distilling what’s left into something the rest of the strategy can stand on. Skip it, and everything downstream is just a well-produced guess.',
  },
  {
    t: 'Strategic translation',
    b: 'Those insights become a plan: what your brand should say, what to prioritize, and how to amplify the third-party sources AI already leans on. This is the part that’s hard to fake.',
  },
  {
    t: 'Content activation',
    b: 'The strategy turns into content built to be extracted and cited — structured so the odds of getting pulled into an answer move in your favor.',
  },
  {
    t: 'Monitoring',
    b: 'I track what AI says next and whether citations are turning into real traffic, then feed that back into the intelligence — so the gains compound instead of fading.',
  },
];
---
<div class="loop">
  <div class="loop__visual">
    <div class="loop__ring" aria-hidden="true"><img src="/brand/logo/monogram-rust.svg" alt="" /></div>
    <ol class="loop__nodes">
      {stages.map((s, i) => (
        <li class={`loop__node loop__node--${i + 1} ${i === 0 ? 'is-active' : ''}`}>
          <button type="button" data-i={i}>
            <span class="loop__n">{i + 1}</span>
            <span class="loop__t">{s.t}</span>
          </button>
        </li>
      ))}
    </ol>
  </div>
  <div class="loop__panel">
    <p class="loop__hint">Hover a stage to see how it works ↓</p>
    {stages.map((s, i) => (
      <div class={`loop__blurb ${i === 0 ? 'is-active' : ''}`} data-i={i}>
        <h3>{s.t}</h3>
        <p>{s.b}</p>
      </div>
    ))}
  </div>
</div>

<style>
  .loop { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: var(--space-5); align-items: center; }
  .loop__visual { position: relative; width: 100%; max-width: 440px; aspect-ratio: 1 / 1; margin-inline: auto; }
  .loop__ring {
    position: absolute; top: 50%; left: 50%; width: 50%; height: 50%;
    transform: translate(-50%, -50%);
    border: 2px dashed var(--olive); border-radius: 50%;
    display: grid; place-items: center;
  }
  .loop__ring img { width: 56%; height: auto; opacity: 0.9; }
  .loop__nodes { list-style: none; margin: 0; padding: 0; }
  .loop__node { position: absolute; width: 40%; }
  .loop__node button {
    width: 100%; cursor: pointer; font: inherit; text-align: center;
    background: var(--cream); color: var(--brown);
    border: 2px solid transparent; border-radius: 14px;
    padding: var(--space-2) var(--space-1);
    box-shadow: var(--shadow-card);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .loop__node button:hover, .loop__node.is-active button {
    border-color: var(--rust); transform: translateY(-3px); box-shadow: var(--shadow-soft);
  }
  .loop__n {
    display: inline-flex; align-items: center; justify-content: center;
    width: 1.8rem; height: 1.8rem; border-radius: 50%;
    background: var(--rust); color: var(--cream); font-family: var(--font-heading);
    margin-bottom: 0.3rem;
  }
  .loop__t { display: block; color: var(--rust); font-weight: 600; font-size: var(--text-sm); }
  .loop__node--1 { top: 0; left: 50%; transform: translateX(-50%); }
  .loop__node--2 { top: 50%; right: 0; transform: translateY(-50%); }
  .loop__node--3 { bottom: 0; left: 50%; transform: translateX(-50%); }
  .loop__node--4 { top: 50%; left: 0; transform: translateY(-50%); }

  .loop__hint { font-style: italic; opacity: 0.7; font-size: var(--text-sm); }
  .loop__blurb { display: none; }
  .loop__blurb.is-active { display: block; }
  .loop__blurb h3 { margin-top: 0; }

  @media (max-width: 760px) {
    .loop { grid-template-columns: 1fr; gap: var(--space-4); }
    .loop__visual { max-width: 360px; }
    .loop__hint { display: none; }
  }
</style>

<script>
  document.querySelectorAll('.loop').forEach((loop) => {
    const nodes = loop.querySelectorAll('.loop__node');
    const blurbs = loop.querySelectorAll('.loop__blurb');
    const hint = loop.querySelector('.loop__hint');
    const activate = (i: number) => {
      nodes.forEach((n, j) => n.classList.toggle('is-active', j === i));
      blurbs.forEach((b, j) => b.classList.toggle('is-active', j === i));
      if (hint instanceof HTMLElement) hint.style.display = 'none';
    };
    loop.querySelectorAll<HTMLButtonElement>('.loop__node button').forEach((btn, i) => {
      btn.addEventListener('mouseenter', () => activate(i));
      btn.addEventListener('focus', () => activate(i));
      btn.addEventListener('click', () => activate(i));
    });
  });
</script>
