---
// A one-month engagement shown as a calendar: four week-rows; hovering / tapping
// a week highlights it and reveals that week's detail. Reuses the site's
// hover-reveal interaction pattern.
interface Week { label: string; title: string; desc: string }
interface Props { weeks: Week[] }
const { weeks } = Astro.props;
const weekdays = ['M', 'T', 'W', 'T', 'F', 'S', 'S'];
---
<div class="cal">
  <div class="cal__sheet">
    <div class="cal__row cal__row--head" aria-hidden="true">
      <span class="cal__wk"></span>
      <span class="cal__days">{weekdays.map((d) => <span class="cal__dow">{d}</span>)}</span>
    </div>
    {weeks.map((w, i) => (
      <button type="button" class:list={['cal__week', i === 0 && 'is-active']} data-i={i}>
        <span class="cal__wk">Wk {i + 1}</span>
        <span class="cal__days">
          {Array.from({ length: 7 }, (_, d) => <span class="cal__day">{i * 7 + d + 1}</span>)}
        </span>
      </button>
    ))}
  </div>
  <div class="cal__panel">
    {weeks.map((w, i) => (
      <div class:list={['cal__detail', i === 0 && 'is-active']} data-i={i}>
        <p class="subhead">Week {i + 1} · {w.label}</p>
        <h3>{w.title}</h3>
        <p>{w.desc}</p>
      </div>
    ))}
  </div>
</div>

<style>
  .cal { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: var(--space-4); align-items: start; }
  .cal__sheet { background: var(--cream); border-radius: 16px; padding: var(--space-2); box-shadow: var(--shadow-card); display: grid; gap: 6px; }
  .cal__row, .cal__week { display: flex; align-items: center; gap: 8px; width: 100%; }
  .cal__week { cursor: pointer; font: inherit; background: transparent; border: 2px solid transparent; border-radius: 12px; padding: 5px; transition: border-color 0.15s ease; }
  .cal__week { position: relative; }
  .cal__week:hover, .cal__week.is-active { border-color: var(--rust); }
  .cal__week.is-active::after {
    content: '›'; position: absolute; right: -22px; top: 50%; transform: translateY(-50%);
    color: var(--rust); font-size: 1.7rem; font-weight: 700; line-height: 1;
  }
  @media (max-width: 760px) { .cal__week.is-active::after { display: none; } }
  .cal__wk { flex: 0 0 44px; font-family: var(--font-sub); font-weight: 800; font-style: italic; color: var(--olive); font-size: var(--text-sm); text-align: left; }
  .cal__days { display: flex; gap: 6px; flex: 1; }
  .cal__dow { flex: 1; text-align: center; font-size: 0.7rem; color: var(--color-text-muted); }
  .cal__day { flex: 1; aspect-ratio: 1; display: grid; place-items: center; border-radius: 8px; background: var(--cream-deep); color: var(--brown); font-size: var(--text-sm); }
  .cal__week:hover .cal__day, .cal__week.is-active .cal__day { background: var(--rust); color: var(--cream); }

  .cal__panel { background: var(--cream); color: var(--brown); border-radius: 16px; padding: var(--space-3); box-shadow: var(--shadow-card); min-height: 11rem; transition: transform 0.3s ease; }
  .cal__detail .subhead { color: var(--olive); opacity: 1; }
  .cal__detail { display: none; }
  .cal__detail.is-active { display: block; }
  .cal__detail h3 { color: var(--rust); margin: 0.2rem 0; }
  .cal__detail p { margin-bottom: 0; }

  @media (max-width: 760px) { .cal { grid-template-columns: 1fr; } }
</style>

<script>
  document.querySelectorAll('.cal').forEach((cal) => {
    const weeks = cal.querySelectorAll<HTMLElement>('.cal__week');
    const details = cal.querySelectorAll('.cal__detail');
    const panel = cal.querySelector<HTMLElement>('.cal__panel');
    const sheet = cal.querySelector<HTMLElement>('.cal__sheet');
    const activate = (i: number) => {
      weeks.forEach((w, j) => w.classList.toggle('is-active', j === i));
      details.forEach((d, j) => d.classList.toggle('is-active', j === i));
      // bump the descriptor panel down to line up with the active week
      if (panel && sheet && window.innerWidth > 760) {
        const offset = weeks[i].getBoundingClientRect().top - sheet.getBoundingClientRect().top;
        const max = Math.max(0, sheet.offsetHeight - panel.offsetHeight);
        panel.style.transform = `translateY(${Math.min(Math.max(0, offset), max)}px)`;
      }
    };
    let current = 0;
    weeks.forEach((w, i) => {
      w.addEventListener('mouseenter', () => { current = i; activate(i); });
      w.addEventListener('focus', () => { current = i; activate(i); });
      w.addEventListener('click', () => { current = i; activate(i); });
    });

    // advance the active week as the calendar scrolls through view
    const onScroll = () => {
      const rect = cal.getBoundingClientRect();
      const vh = window.innerHeight;
      // spread the 4 weeks across the calendar's whole pass through the screen,
      // so week 1 holds well into view before 2 -> 3 -> 4 advance
      const raw = Math.min(1, Math.max(0, (vh * 0.7 - rect.top) / (vh * 0.6)));
      const idx = Math.min(weeks.length - 1, Math.floor(raw * weeks.length));
      if (idx !== current) { current = idx; activate(idx); }
    };
    onScroll();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { onScroll(); ticking = false; });
    }, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  });
</script>
