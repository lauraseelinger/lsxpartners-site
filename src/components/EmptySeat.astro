---
// The team table: three seats already filled (solid olive figures), and the
// AI-visibility seat sitting empty as a dotted rust stick figure with no head.
// As the section scrolls through view, Laura's real head travels in and lands
// on the stick figure — the gap you had, easily filled. Scroll-progress driven.
---
<div class="seats" data-seats>
  <div class="seats__row">
    {[0, 1, 2].map(() => (
      <svg class="mate" viewBox="0 0 60 116" aria-hidden="true">
        <circle cx="30" cy="16" r="12" fill="var(--olive)" />
        <g fill="none" stroke="var(--olive)" stroke-width="4" stroke-linecap="round">
          <line x1="30" y1="30" x2="30" y2="74" />
          <line x1="30" y1="44" x2="12" y2="62" />
          <line x1="30" y1="44" x2="48" y2="62" />
          <line x1="30" y1="74" x2="16" y2="110" />
          <line x1="30" y1="74" x2="44" y2="110" />
        </g>
      </svg>
    ))}
    <div class="me">
      <svg class="stick" viewBox="0 0 100 150" aria-hidden="true" fill="none" stroke="var(--rust)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="3 7">
        <circle cx="50" cy="28" r="20" class="stick__head" />
        <line x1="50" y1="48" x2="50" y2="104" />
        <line x1="50" y1="66" x2="24" y2="92" />
        <line x1="50" y1="66" x2="80" y2="46" />
        <line x1="50" y1="104" x2="28" y2="142" />
        <line x1="50" y1="104" x2="72" y2="142" />
      </svg>
      <img class="me__face" src="/images/laura-cutout.png" alt="Laura Seelinger" data-head />
      <span class="me__tag">AI visibility expert</span>
    </div>
  </div>
  <div class="seats__floor" aria-hidden="true"></div>
</div>

<style>
  .seats { width: min(480px, 100%); margin-inline: auto; }
  .seats__row { display: flex; align-items: flex-end; justify-content: center; gap: var(--space-2); position: relative; z-index: 2; }
  .mate { width: 40px; height: auto; opacity: 0.8; }
  .me { position: relative; width: 100px; flex: none; }
  .stick { width: 100%; height: auto; display: block; transition: stroke-dasharray 0.3s ease; }
  .stick.is-filled { stroke-dasharray: none; }
  .me__face {
    position: absolute; left: 50%; top: -4%; width: 64%; height: auto; z-index: 3;
    transform: translate(-50%, 0) scale(1); transform-origin: center;
  }
  .me__tag {
    position: absolute; top: 100%; left: 50%; transform: translateX(-50%); margin-top: 6px;
    white-space: nowrap; font-family: var(--font-sub); font-style: italic; font-weight: 800;
    color: var(--rust); font-size: var(--text-sm);
  }
  .seats__floor {
    height: 14px; border-radius: 0 0 10px 10px;
    background: color-mix(in srgb, var(--brown) 65%, var(--cream));
    margin-top: -7px; box-shadow: var(--shadow-card); position: relative; z-index: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .me__face { transition: none; }
  }
</style>

<script>
  document.querySelectorAll('[data-seats]').forEach((seats) => {
    const head = seats.querySelector('[data-head]') as HTMLElement | null;
    const stick = seats.querySelector('.stick') as HTMLElement | null;
    if (!head) return;
    // head travels in from above-right and lands on the stick figure as the
    // section scrolls through the viewport
    const update = () => {
      const rect = seats.getBoundingClientRect();
      const vh = window.innerHeight;
      // 0 when the block first enters the lower viewport, 1 once it's settled higher up
      const p = Math.min(1, Math.max(0, (vh * 0.9 - rect.top) / (vh * 0.55)));
      const x = 70 * (1 - p);      // drift in from the right
      const y = -130 * (1 - p);    // drop down from above
      const scale = 0.65 + 0.35 * p;
      head.style.transform = `translate(calc(-50% + ${x}px), ${y}px) scale(${scale})`;
      head.style.opacity = String(0.15 + 0.85 * p);
      if (stick) stick.classList.toggle('is-filled', p > 0.82);
    };
    update();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    }, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  });
</script>
