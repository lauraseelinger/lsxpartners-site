---
// A round boardroom table seen in perspective. Five seats are filled with
// placeholder teammate avatars (olive silhouette in a circle); one seat — the
// AI-visibility seat — is filled by Laura's real photo, sized to match the
// silhouette heads and ringed in rust so it reads as "the real expert among
// the team." Hand-drawn arrow labels call out team vs. expert.
const mates = [
  { cls: 'pos-a' },   // left
  { cls: 'pos-b' },   // back-left
  { cls: 'pos-c' },   // back-center
  { cls: 'pos-d' },   // back-right
  { cls: 'pos-e' },   // front-left
];
---
<div class="board" data-board>
  <!-- table -->
  <svg class="board__table" viewBox="0 0 540 360" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
    <ellipse cx="270" cy="228" rx="210" ry="72" fill="var(--brown)" />
    <ellipse cx="270" cy="218" rx="210" ry="72" fill="color-mix(in srgb, var(--brown) 82%, var(--cream))" />
    <ellipse cx="270" cy="218" rx="168" ry="52" fill="color-mix(in srgb, var(--brown) 70%, var(--cream))" />
  </svg>

  <!-- teammate seats -->
  {mates.map((m) => (
    <div class:list={['bub', m.cls]}>
      <span class="chair" aria-hidden="true"></span>
      <span class="ava ava--mate">
        <svg viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="24" r="13" fill="var(--olive)" />
          <path d="M10 60 C10 43 54 43 54 60 Z" fill="var(--olive)" />
        </svg>
      </span>
    </div>
  ))}

  <!-- my seat -->
  <div class="bub pos-me">
    <span class="chair chair--me" aria-hidden="true"></span>
    <span class="ava ava--me" data-seat>
      <svg class="ava__ghost" viewBox="0 0 64 64" aria-hidden="true">
        <circle cx="32" cy="24" r="13" fill="none" stroke="var(--rust)" stroke-width="2.5" stroke-dasharray="3 4" />
        <path d="M10 60 C10 43 54 43 54 60 Z" fill="none" stroke="var(--rust)" stroke-width="2.5" stroke-dasharray="3 4" />
      </svg>
      <img class="ava__photo" src="/images/laura-cutout.png" alt="Laura Seelinger" data-head />
    </span>
  </div>

  <!-- labels -->
  <div class="tag tag--team" aria-hidden="true">
    <span class="tag__note">Your team</span>
    <svg class="tag__arrow" viewBox="0 0 110 90" fill="none">
      <path d="M6 12 C 60 8 96 26 96 66" stroke="var(--brown)" stroke-width="5" stroke-linecap="round" />
      <path d="M80 56 L97 70 L106 50" stroke="var(--brown)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
  <div class="tag tag--me" aria-hidden="true">
    <svg class="tag__arrow tag__arrow--up" viewBox="0 0 60 86" fill="none">
      <path d="M30 80 C 28 50 32 40 30 12" stroke="var(--rust)" stroke-width="5" stroke-linecap="round" />
      <path d="M16 26 L30 8 L44 26" stroke="var(--rust)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span class="tag__note tag__note--rust">AI visibility expert</span>
  </div>
</div>

<style>
  .board { position: relative; width: min(540px, 100%); aspect-ratio: 3 / 2; margin-inline: auto; }
  .board__table { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; filter: drop-shadow(0 8px 14px rgba(58, 42, 30, 0.18)); }

  .bub { position: absolute; width: 80px; transform: translate(-50%, -50%); z-index: 2; }
  .pos-a { left: 9%; top: 42%; }
  .pos-b { left: 27%; top: 20%; }
  .pos-c { left: 50%; top: 15%; }
  .pos-d { left: 73%; top: 20%; }
  .pos-e { left: 31%; top: 77%; }
  .pos-me { left: 85%; top: 42%; }

  /* chair back peeking behind each avatar */
  .chair { position: absolute; left: 50%; top: 54%; width: 64px; height: 76px; transform: translate(-50%, -50%);
    background: color-mix(in srgb, var(--olive) 30%, var(--cream)); border-radius: 16px 16px 10px 10px; z-index: -1; }
  .chair--me { background: color-mix(in srgb, var(--rust) 22%, var(--cream)); }

  .ava { position: relative; display: grid; place-items: center; width: 80px; height: 80px; border-radius: 50%;
    overflow: hidden; background: var(--cream); box-shadow: var(--shadow-card); }
  .ava--mate svg { width: 100%; height: 100%; }

  /* my seat: empty dotted silhouette, then my real photo floats in to fill it */
  .ava--me { border: 2.5px solid var(--rust); overflow: visible; }
  .ava__ghost { position: absolute; inset: 0; width: 100%; height: 100%; transition: opacity 0.3s ease; }
  .ava--me.is-filled .ava__ghost { opacity: 0.18; }
  .ava__photo {
    position: absolute; top: 8%; left: 50%; transform: translate(-50%, 0);
    width: 86%; height: auto; opacity: 0;
    -webkit-mask-image: radial-gradient(120% 90% at 50% 36%, #000 66%, transparent 100%);
    mask-image: radial-gradient(120% 90% at 50% 36%, #000 66%, transparent 100%);
  }
  @media (prefers-reduced-motion: reduce) {
    .ava__photo { opacity: 1 !important; transform: translate(-50%, 0) !important; }
    .ava--me.is-filled .ava__ghost { opacity: 0.18; }
  }

  /* arrow labels */
  .tag { position: absolute; display: flex; align-items: center; gap: 2px; z-index: 3; }
  .tag__note {
    font-family: var(--font-sub); font-weight: 800; font-style: italic; font-size: var(--text-lg);
    color: var(--brown); background: var(--cream); padding: 0.4rem 0.85rem; border-radius: 10px;
    box-shadow: var(--shadow-card); white-space: nowrap; line-height: 1.1;
  }
  .tag__note--rust { color: var(--rust); }
  .tag__arrow { width: 56px; height: auto; flex: none; }
  .tag--team { left: 1%; top: -5%; transform: rotate(-3deg); }
  .tag--team .tag__note { transform: rotate(1deg); }
  .tag--me { left: 85%; top: 57%; transform: translateX(-50%); flex-direction: column; align-items: center; gap: 0; }
  .tag--me .tag__arrow--up { width: 30px; }

  @media (max-width: 560px) {
    .bub, .ava, .chair { width: 62px; }
    .ava { height: 62px; }
    .chair { height: 58px; }
    .tag__note { font-size: var(--text-sm); }
    .tag__arrow { width: 40px; }
    .tag--me .tag__arrow--up { width: 24px; }
  }
</style>

<script>
  // The empty seat fills: my photo floats down into place as the section
  // scrolls through view, and the dotted silhouette fades behind it.
  document.querySelectorAll('[data-board]').forEach((board) => {
    const photo = board.querySelector('[data-head]') as HTMLElement | null;
    const seat = board.querySelector('.ava--me') as HTMLElement | null;
    if (!photo) return;
    const update = () => {
      const rect = board.getBoundingClientRect();
      const vh = window.innerHeight;
      // raw progress as the table moves up through view (done while centered,
      // not after it has scrolled off)
      const span = vh * 0.85;
      const raw = Math.min(1, Math.max(0, (vh - rect.top) / span));
      // brief hold on the empty silhouette, then glide in and finish in-view
      const t = Math.min(1, Math.max(0, (raw - 0.16) / 0.5));
      const e = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;  // ease-in-out
      const x = 220 * (1 - e);            // come in from far right
      const y = 40 * (1 - e);             // and slightly up
      const scale = 0.7 + 0.3 * e;
      photo.style.transform = `translate(calc(-50% + ${x}px), ${y}px) scale(${scale})`;
      photo.style.opacity = String(t);
      if (seat) seat.classList.toggle('is-filled', t > 0.9);
    };
    update();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    }, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  });
</script>
