---
// A round boardroom table seen in perspective. Three seats are filled with
// placeholder teammate avatars (olive silhouette in a circle); one seat — the
// AI-visibility seat — sits empty as a dotted rust ring. As the section scrolls
// into view, Laura's real (feathered) photo drops into that seat: the gap your
// team has, easily filled. Hand-drawn arrow labels call out team vs. expert.
const mates = [
  { cls: 'pos-a' },   // left
  { cls: 'pos-b' },   // back-left
  { cls: 'pos-c' },   // back-right
];
---
<div class="board" data-seats>
  <!-- table -->
  <svg class="board__table" viewBox="0 0 540 360" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
    <ellipse cx="270" cy="228" rx="210" ry="72" fill="var(--brown)" />
    <ellipse cx="270" cy="218" rx="210" ry="72" fill="color-mix(in srgb, var(--brown) 82%, var(--cream))" />
    <ellipse cx="270" cy="218" rx="168" ry="52" fill="color-mix(in srgb, var(--brown) 70%, var(--cream))" />
  </svg>

  <!-- teammate seats -->
  {mates.map((m) => (
    <div class:list={['bub', m.cls]}>
      <span class="chair" aria-hidden="true"></span>
      <span class="ava ava--mate">
        <svg viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="24" r="13" fill="var(--olive)" />
          <path d="M10 60 C10 43 54 43 54 60 Z" fill="var(--olive)" />
        </svg>
      </span>
    </div>
  ))}

  <!-- my seat -->
  <div class="bub pos-me">
    <span class="chair chair--me" aria-hidden="true"></span>
    <span class="ava ava--me" data-seat>
      <span class="ring" aria-hidden="true"></span>
      <img class="ava__photo" src="/images/laura-cutout.png" alt="Laura Seelinger" data-head />
    </span>
  </div>

  <!-- labels -->
  <div class="tag tag--team" aria-hidden="true">
    <span class="tag__note">Your team</span>
    <svg class="tag__arrow" viewBox="0 0 110 90" fill="none">
      <path d="M6 12 C 60 8 96 26 96 66" stroke="var(--brown)" stroke-width="5" stroke-linecap="round" />
      <path d="M80 56 L97 70 L106 50" stroke="var(--brown)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
  <div class="tag tag--me" aria-hidden="true">
    <svg class="tag__arrow tag__arrow--up" viewBox="0 0 110 90" fill="none">
      <path d="M104 78 C 50 82 14 64 14 24" stroke="var(--rust)" stroke-width="5" stroke-linecap="round" />
      <path d="M30 34 L13 18 L4 40" stroke="var(--rust)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span class="tag__note tag__note--rust">AI visibility expert</span>
  </div>
</div>

<style>
  .board { position: relative; width: min(540px, 100%); aspect-ratio: 3 / 2; margin-inline: auto; }
  .board__table { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; filter: drop-shadow(0 8px 14px rgba(58, 42, 30, 0.18)); }

  .bub { position: absolute; width: 84px; transform: translate(-50%, -50%); z-index: 2; }
  .pos-a { left: 16%; top: 49%; }
  .pos-b { left: 33%; top: 25%; }
  .pos-c { left: 67%; top: 25%; }
  .pos-me { left: 84%; top: 49%; }

  /* chair back peeking behind each avatar */
  .chair { position: absolute; left: 50%; top: 54%; width: 66px; height: 78px; transform: translate(-50%, -50%);
    background: color-mix(in srgb, var(--olive) 30%, var(--cream)); border-radius: 16px 16px 10px 10px; z-index: -1; }
  .chair--me { background: color-mix(in srgb, var(--rust) 20%, var(--cream)); }

  .ava { position: relative; display: grid; place-items: center; width: 84px; height: 84px; border-radius: 50%; overflow: hidden;
    background: var(--cream); box-shadow: var(--shadow-card); }
  .ava--mate svg { width: 100%; height: 100%; }

  /* my empty seat → filled */
  .ava--me { overflow: visible; }
  .ring { position: absolute; inset: 0; border-radius: 50%; border: 2.5px dashed var(--rust);
    transition: border-color 0.3s ease, border-style 0.3s ease; }
  .ava__photo {
    width: 100%; height: 100%; border-radius: 50%; object-fit: cover; object-position: center 28%;
    -webkit-mask-image: radial-gradient(closest-side, #000 70%, transparent 100%);
    mask-image: radial-gradient(closest-side, #000 70%, transparent 100%);
    transform-origin: center;
  }
  .ava--me.is-filled .ring { border-style: solid; border-color: color-mix(in srgb, var(--rust) 55%, transparent); }

  /* arrow labels */
  .tag { position: absolute; display: flex; align-items: center; gap: 2px; z-index: 3; }
  .tag__note {
    font-family: var(--font-sub); font-weight: 800; font-style: italic; font-size: var(--text-lg);
    color: var(--brown); background: var(--cream); padding: 0.4rem 0.85rem; border-radius: 10px;
    box-shadow: var(--shadow-card); white-space: nowrap; line-height: 1.1;
  }
  .tag__note--rust { color: var(--rust); }
  .tag__arrow { width: 58px; height: auto; flex: none; }
  .tag--team { left: -2%; top: -6%; transform: rotate(-3deg); }
  .tag--team .tag__note { transform: rotate(1deg); }
  .tag--me { right: -4%; bottom: -4%; transform: rotate(2deg); }

  @media (max-width: 560px) {
    .bub { width: 64px; }
    .ava, .chair { width: 64px; }
    .ava { height: 64px; }
    .chair { height: 60px; }
    .tag__note { font-size: var(--text-sm); }
    .tag__arrow { width: 42px; }
  }
</style>

<script>
  document.querySelectorAll('[data-seats]').forEach((board) => {
    const photo = board.querySelector('[data-head]') as HTMLElement | null;
    const seat = board.querySelector('.ava--me') as HTMLElement | null;
    if (!photo) return;
    const update = () => {
      const rect = board.getBoundingClientRect();
      const vh = window.innerHeight;
      const p = Math.min(1, Math.max(0, (vh * 0.9 - rect.top) / (vh * 0.55)));
      const y = -52 * (1 - p);      // drop in from above
      const scale = 0.72 + 0.28 * p;
      photo.style.transform = `translateY(${y}px) scale(${scale})`;
      photo.style.opacity = String(0.08 + 0.92 * p);
      if (seat) seat.classList.toggle('is-filled', p > 0.8);
    };
    update();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    }, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  });
</script>
