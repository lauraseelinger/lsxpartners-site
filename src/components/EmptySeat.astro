---
// A team's table with empty chairs — the seat your team isn't staffed for.
// One rust stick figure stands at the open seat with a blank, outlined head.
// As the section scrolls in, Laura's real cutout drops onto the head: the
// empty seat, filled. Satire-illustration vibe — a stick figure with a real face.
---
<div class="seats">
  <div class="seats__row">
    {[0, 1, 2].map(() => (
      <svg class="chair" viewBox="0 0 60 96" aria-hidden="true" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <rect x="15" y="6" width="30" height="44" rx="7" />
        <rect x="10" y="50" width="40" height="11" rx="5" />
        <line x1="16" y1="61" x2="16" y2="92" />
        <line x1="44" y1="61" x2="44" y2="92" />
      </svg>
    ))}
    <div class="me">
      <svg class="stick" viewBox="0 0 92 150" aria-hidden="true" fill="none" stroke="var(--rust)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="46" cy="26" r="19" class="stick__head" />
        <line x1="46" y1="45" x2="46" y2="102" />
        <line x1="46" y1="62" x2="22" y2="86" />
        <line x1="46" y1="62" x2="76" y2="44" />
        <line x1="46" y1="102" x2="26" y2="140" />
        <line x1="46" y1="102" x2="66" y2="140" />
      </svg>
      <img class="me__face" src="/images/laura-cutout.png" alt="Laura Seelinger" data-reveal />
      <span class="me__tag">AI visibility expert</span>
    </div>
  </div>
  <div class="seats__floor" aria-hidden="true"></div>
</div>

<style>
  .seats { width: min(460px, 100%); margin-inline: auto; }
  .seats__row { display: flex; align-items: flex-end; justify-content: center; gap: var(--space-2); position: relative; z-index: 2; }
  .chair { width: 42px; height: auto; stroke: color-mix(in srgb, var(--olive) 60%, transparent); opacity: 0.7; }
  .me { position: relative; width: 92px; flex: none; }
  .stick { width: 100%; height: auto; display: block; }
  .me__face {
    position: absolute; top: -8%; left: 50%; transform: translateX(-50%);
    width: 50%; height: auto; z-index: 3;
  }
  /* empty head until scrolled into view, then the real face drops on */
  .me__face[data-reveal] { opacity: 0; transform: translateX(-50%) translateY(-10px) scale(0.85); transition: opacity 0.5s ease, transform 0.5s ease; }
  .me__face[data-reveal].in-view { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
  .me__tag {
    position: absolute; top: 100%; left: 50%; transform: translateX(-50%); margin-top: 6px;
    white-space: nowrap; font-family: var(--font-sub); font-style: italic; font-weight: 800;
    color: var(--rust); font-size: var(--text-sm);
  }
  .seats__floor {
    height: 14px; border-radius: 0 0 10px 10px;
    background: color-mix(in srgb, var(--brown) 65%, var(--cream));
    margin-top: -7px; box-shadow: var(--shadow-card); position: relative; z-index: 1;
  }
</style>
