---
// Your team at a table: three seats filled (solid olive head-and-shoulders
// avatars), and one empty seat — the AI-visibility seat — drawn as a dotted
// rust outline with no face. As the section scrolls through view, Laura's
// real head travels in and lands on the empty seat, which then fills solid:
// the gap you had, easily filled. All seats are the same scale.
const mates = [0, 1, 2];
---
<div class="seats" data-seats>
  <div class="seats__people">
    {mates.map(() => (
      <svg class="seat mate" viewBox="0 0 64 84" aria-hidden="true">
        <circle cx="32" cy="20" r="13" fill="var(--olive)" />
        <path d="M6 84 C6 54 58 54 58 84 Z" fill="var(--olive)" />
      </svg>
    ))}
    <div class="me seat-wrap">
      <svg class="seat seat--empty" viewBox="0 0 64 84" aria-hidden="true" fill="none" stroke="var(--rust)" stroke-width="3" stroke-linejoin="round" stroke-dasharray="2.5 6">
        <circle cx="32" cy="20" r="13" />
        <path class="seat__body" d="M6 84 C6 54 58 54 58 84 Z" />
      </svg>
      <img class="me__face" src="/images/laura-cutout.png" alt="Laura Seelinger" data-head />
    </div>
  </div>
  <div class="seats__table" aria-hidden="true"></div>
  <p class="seats__tag">your AI visibility seat</p>
</div>

<style>
  .seats { width: min(480px, 100%); margin-inline: auto; }
  .seats__people { display: flex; align-items: flex-end; justify-content: center; gap: var(--space-3); position: relative; z-index: 1; }
  .seat { width: 64px; height: auto; }
  .mate { opacity: 0.85; }
  .seat-wrap { position: relative; width: 64px; flex: none; }
  .seat--empty { display: block; opacity: 0.75; }
  .seat__body { transition: fill 0.3s ease; }
  .seat--empty.is-filled { stroke-dasharray: none; opacity: 1; }
  .seat--empty.is-filled .seat__body { fill: var(--rust); }
  .me__face {
    position: absolute; left: 50%; top: -6%; width: 74%; height: auto; z-index: 3;
    transform: translate(-50%, 0) scale(1); transform-origin: center;
  }
  /* The table sits in front of the lower torsos so the row reads as seated */
  .seats__table {
    position: relative; z-index: 2; height: 22px; border-radius: 6px 6px 10px 10px;
    margin-top: -20px;
    background: linear-gradient(var(--brown), color-mix(in srgb, var(--brown) 78%, var(--cream)));
    box-shadow: var(--shadow-card);
  }
  .seats__tag {
    margin: 0.6rem 0 0; text-align: right; padding-right: 8%;
    font-family: var(--font-sub); font-style: italic; font-weight: 800;
    color: var(--rust); font-size: var(--text-sm);
  }
  @media (prefers-reduced-motion: reduce) { .me__face { transition: none; } }
</style>

<script>
  document.querySelectorAll('[data-seats]').forEach((seats) => {
    const head = seats.querySelector('[data-head]') as HTMLElement | null;
    const empty = seats.querySelector('.seat--empty') as HTMLElement | null;
    if (!head) return;
    const update = () => {
      const rect = seats.getBoundingClientRect();
      const vh = window.innerHeight;
      const p = Math.min(1, Math.max(0, (vh * 0.9 - rect.top) / (vh * 0.55)));
      const x = 55 * (1 - p);      // drift in from the right
      const y = -95 * (1 - p);     // drop down from above
      const scale = 0.7 + 0.3 * p;
      head.style.transform = `translate(calc(-50% + ${x}px), ${y}px) scale(${scale})`;
      head.style.opacity = String(0.12 + 0.88 * p);
      if (empty) empty.classList.toggle('is-filled', p > 0.82);
    };
    update();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    }, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  });
</script>
