---
// Photo treatments: soft rounded (with shadow), circle, or feathered edges
// that fade into the background so the image blends in rather than sitting as
// a separate hard rectangle. No hard borders / scalloped edges.
interface Props {
  src: string;
  alt: string;
  shape?: 'rounded' | 'circle' | 'feather';
  reveal?: boolean;
  delay?: '1' | '2' | '3';
  ratio?: string;
  class?: string;
}
const { src, alt, shape = 'rounded', reveal = false, delay, ratio = '4 / 5', class: cls = '' } = Astro.props;
---
<figure
  class:list={['framed', `framed--${shape}`, cls]}
  style={`--ratio:${ratio}`}
  data-reveal={reveal ? '' : undefined}
  data-reveal-delay={delay}
>
  <img src={src} alt={alt} loading="lazy" />
</figure>

<style>
  .framed { margin: 0; }
  .framed img {
    display: block;
    width: 100%;
    aspect-ratio: var(--ratio);
    object-fit: cover;
  }
  .framed--rounded img { border-radius: 16px; box-shadow: var(--shadow-soft); }
  .framed--circle img { aspect-ratio: 1 / 1; border-radius: 50%; box-shadow: var(--shadow-soft); }
  /* Feathered: edges fade to transparent so the photo melts into the section */
  .framed--feather img {
    -webkit-mask-image: radial-gradient(78% 84% at 50% 44%, #000 32%, transparent 80%);
    mask-image: radial-gradient(78% 84% at 50% 44%, #000 32%, transparent 80%);
  }
</style>
