---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

// One static page per post. Slug = the markdown filename, so URLs are
// controlled by file naming → lets us preserve every legacy /blog/<slug>.
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const listed = posts.filter((p) => !p.data.unlisted);
  return posts.map((post) => {
    // internal linking: other listed posts sharing a tag, newest first
    const related = listed
      .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3)
      .map((p) => ({ id: p.id, title: p.data.title, heroImage: p.data.heroImage }));
    return { params: { slug: post.id }, props: { post, related } };
  });
}

const { post, related } = Astro.props;
const { Content } = await render(post);
---
<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  heroImage={post.data.heroImage}
  register={post.data.register}
  faqs={post.data.faqs}
  related={related}
>
  <Content />
</BlogPost>
