---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import StitchDivider from '../../../components/StitchDivider.astro';
import FAQ from '../../../components/FAQ.astro';
import type { FaqItem } from '../../../lib/schema';
import { CTA, BLOG_CATEGORIES, catLabel } from '../../../consts';

// Per-category Q&A — renders a visible FAQ block AND FAQPage JSON-LD (AEO), so
// each category page can itself get surfaced/cited for these buyer questions.
const categoryFaqs: Record<string, FaqItem[]> = {
  'ai-visibility': [
    { question: 'What is AI visibility?', answer: 'AI visibility is whether AI tools — ChatGPT, Claude, Gemini, Perplexity, Google’s AI Overviews — mention your brand when someone asks about your category, and whether they credit you as the source. It’s the new version of showing up on page one, except there’s often one answer and you’re either in it or you’re not.' },
    { question: 'How is AI visibility different from SEO?', answer: 'SEO gets you into a ranked list of links a person clicks through. AI visibility gets you named inside the answer the AI writes — frequently with no click at all. They share fundamentals (clear, trustworthy, well-structured content wins both), but optimizing for a list and optimizing to be quoted are different jobs.' },
    { question: 'How do I find out if AI mentions my brand?', answer: 'Run the real questions your buyers ask through each major AI engine and record what it says and which sources it cites. That’s an AI visibility audit — and the catch is testing the language buyers actually use, not the wording your marketing team has documented, or you get a confident-looking false positive.' },
  ],
  guides: [
    { question: 'How do I get my brand cited by AI?', answer: 'Be the clearest, most trustworthy answer to the question your buyer is actually asking. In practice that means content structured so AI can extract it, the answer front-loaded in the first lines, and a presence on the third-party sources AI leans on — not just your own site.' },
    { question: 'What is answer engine optimization (AEO)?', answer: 'AEO is optimizing your content to be the answer an AI engine gives, not just a link it lists. It’s the close cousin of GEO (generative engine optimization) — same goal of getting quoted by AI, with the emphasis on directly answering the questions people ask.' },
    { question: 'Can I audit my own AI visibility?', answer: 'Yes — the mechanics are simple: run your buyers’ real questions through ChatGPT, Claude, Gemini and Perplexity and log what they say and cite. The hard part is knowing which questions to test; the wrong prompt set gives you a false positive that looks like good news.' },
  ],
  'audience-intelligence': [
    { question: 'What is audience intelligence?', answer: 'Audience intelligence is a clear read on how your buyers actually talk about their problem — the words, questions, and objections in their own language, pulled from where they really discuss it. It’s the input most strategies skip, and the thing AI visibility depends on.' },
    { question: 'Why don’t keyword tools capture how buyers really talk?', answer: 'Keyword tools show the short, typed phrases people once used in a search box. Buyers describe their problem to AI in full sentences, with context and frustration — language that never shows up in a volume report. You have to go where they actually talk to hear it.' },
    { question: 'Where does real buyer language live?', answer: 'In reviews, community and industry forums, Reddit threads, comment sections, and your own sales calls and DMs — anywhere people describe the problem before they’ve picked a solution. That’s the raw material for both content and AI visibility strategy.' },
  ],
  'marketing-pov': [
    { question: 'Where does AI visibility sit in the bigger marketing picture?', answer: 'It’s a high-leverage channel, not the whole strategy. The audience intelligence behind it — how your buyers actually talk — feeds everything else too: positioning, content, social, experiential. The smart move is to treat AI visibility as the lead, not the limit.' },
    { question: 'Should small and mid-size brands care about AI visibility yet?', answer: 'Yes, and earlier than the big players assume. AI answers surface only a handful of sources per question, and the ones that get cited tend to keep getting cited — so getting in while your category is still uncrowded is the cheap moment to do it.' },
  ],
};

// Tag/category pages at clean kebab-case URLs, e.g. /blog/category/ai-visibility
// (the legacy /blog/category/AI+visibility 301s here — see redirect-map.md).
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && !data.unlisted);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      // categories that have at least one post (for the chip row)
      presentCats: BLOG_CATEGORIES.filter((c) => posts.some((p) => p.data.tags.includes(c.slug))),
    },
  }));
}

const { tag, posts, presentCats } = Astro.props;
const label = catLabel(tag);
const faqs = categoryFaqs[tag] ?? [];
const covers = ['pattern-2', 'pattern-5', 'pattern-3', 'pattern-4', 'pattern-peach'];
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const cover = (p: typeof posts[number], i: number) => {
  const pat = `/brand/patterns/${covers[i % covers.length]}.jpg`;
  return p.data.heroImage
    ? { cls: `has-img from-${p.data.coverFrom}`, style: `background-image:url(${p.data.heroImage}); --pat:url('${pat}')` }
    : { cls: '', style: `background-image: linear-gradient(rgba(139,140,74,0.16), rgba(139,140,74,0.16)), url('${pat}')` };
};
---
<BaseLayout
  title={`${label} — LSX Partners blog`}
  description={`${label} articles by Laura Seelinger — AI visibility, GEO, AEO, and getting your brand cited by AI.`}
>
  <!-- HEADER -->
  <section class="band tex-cream blogx__head">
    <div class="container measure" data-reveal>
      <p class="subhead">the blog</p>
      <h1>{label}</h1>
      <nav class="blogcats" aria-label="Blog categories">
        <a class="chip" href="/blog">All</a>
        {presentCats.map((c) => (
          <a class:list={['chip', c.slug === tag && 'is-current']} href={`/blog/category/${c.slug}`}>{c.label}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- POSTS -->
  <StitchDivider bg="cream" stitch="rust" />
  <section class="band section--cream">
    <div class="container">
      <div class="pgrid">
        {posts.map((post, i) => (
          <a class="pcard" href={`/blog/${post.id}`} data-reveal data-reveal-delay={(i % 3) + 1}>
            <div class:list={['pcard__cover', cover(post, i).cls]} style={cover(post, i).style}>
              <span class="pcard__tag">{label}</span>
            </div>
            <div class="pcard__body">
              <p class="pcard__meta">{fmt(post.data.pubDate)}</p>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="pcard__go">Read →</span>
            </div>
          </a>
        ))}
      </div>

      {faqs.length > 0 && (
        <div class="measure faqwrap" data-reveal>
          <FAQ items={faqs} heading={`Questions about ${label}`} />
        </div>
      )}
    </div>
  </section>

  <!-- SUBSCRIBE -->
  <StitchDivider bg="rust" stitch="yellow" />
  <section class="band section--rust">
    <div class="container measure measure--center" data-reveal="scale">
      <p class="subhead">the newsletter</p>
      <h2>Get it in your inbox: <em>Cited</em></h2>
      <p>The same no-fluff takes on AI visibility, before they’re anywhere else.</p>
      <a class="button button--ghost" href={CTA.newsletter}>Subscribe to Cited</a>
    </div>
  </section>
</BaseLayout>

<style>
  .band { padding-block: var(--space-6); }
  .blogx__head { padding-block: var(--space-6); }
  .measure { max-width: 44rem; }
  .measure--center { margin-inline: auto; text-align: center; }
  .measure--center em { font-style: italic; }

  /* category chips */
  .blogcats { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: var(--space-3); }
  .chip {
    text-decoration: none; font-family: var(--font-sub); font-style: italic; font-weight: 800;
    font-size: var(--text-sm); padding: 0.35rem 0.95rem; border-radius: 999px;
    border: 2px solid var(--rust); color: var(--rust); background: transparent;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .chip:hover { background: var(--rust); color: var(--cream); }
  .chip.is-current { background: var(--rust); color: var(--cream); }

  .pcard__meta { font-family: var(--font-sub); font-weight: 800; font-style: italic; color: var(--olive); font-size: var(--text-sm); margin: 0 0 0.3rem; }
  .pcard__go { display: inline-block; margin-top: var(--space-1); font-weight: 700; color: var(--rust); }

  /* grid of cards (matches the blog index) */
  .pgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); }
  .pcard {
    display: flex; flex-direction: column; text-decoration: none; color: inherit;
    background: var(--cream); border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-card);
    border: 2px solid transparent; transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .pcard:hover { transform: translateY(-3px); border-color: var(--rust); }
  .pcard__cover { position: relative; aspect-ratio: 16 / 9; background-size: cover; background-position: center; overflow: hidden; }
  .has-img::before {
    content: ''; position: absolute; inset: 0; z-index: 1; opacity: 0.55;
    background-image: var(--pat); background-size: 190px; background-repeat: repeat;
    --m: linear-gradient(to bottom, rgba(0,0,0,0.82) 0, rgba(0,0,0,0.42) 34%, rgba(0,0,0,0.12) 64%, transparent 90%);
    -webkit-mask-image: var(--m); mask-image: var(--m);
  }
  .from-bottom::before { --m: linear-gradient(to top, rgba(0,0,0,0.82) 0, rgba(0,0,0,0.42) 34%, rgba(0,0,0,0.12) 64%, transparent 90%); }
  .from-left::before { --m: linear-gradient(to right, rgba(0,0,0,0.82) 0, rgba(0,0,0,0.42) 34%, rgba(0,0,0,0.12) 64%, transparent 90%); }
  .from-right::before { --m: linear-gradient(to left, rgba(0,0,0,0.82) 0, rgba(0,0,0,0.42) 34%, rgba(0,0,0,0.12) 64%, transparent 90%); }
  .pcard__tag {
    position: absolute; z-index: 2; bottom: 8px; left: 8px; font-family: var(--font-sub); font-weight: 800; font-style: italic;
    font-size: var(--text-sm); color: var(--cream); background: var(--rust); padding: 0.2rem 0.6rem; border-radius: 999px;
  }
  .pcard__body { padding: var(--space-3); display: flex; flex-direction: column; }
  .pcard__body h3 { margin: 0 0 0.3rem; font-size: var(--text-lg); }
  .pcard__body p { font-size: var(--text-sm); color: var(--color-text-muted); margin: 0; }

  .faqwrap { max-width: 44rem; margin: var(--space-5) auto 0; }

  @media (max-width: 860px) { .pgrid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 680px) { .pgrid { grid-template-columns: 1fr; } }
</style>
