---
import BaseLayout from '../layouts/BaseLayout.astro';
import FramedPhoto from '../components/FramedPhoto.astro';
import { serviceSchema } from '../lib/schema';
import { SITE, PERSON, CTA } from '../consts';

// HOME — varied block treatments + motion (marquee, count-up stats, step
// progression, pull-quote, textured + framed sections). Voice: Full LinkedIn
// Laura. Stats are her own sourced figures.
const marquee = ['ai visibility', 'get cited by ai', 'aeo', 'geo', 'audience intelligence', 'content activation'];
const services = [
  { n: '01', t: 'AI Visibility Audit', d: 'Where you show up — and don’t — across ChatGPT, Claude, Perplexity and Google AI. And the real reason why.' },
  { n: '02', t: 'AI Visibility Strategy', d: 'The plan to get cited, built on what your audience actually asks — not a list of prompts crowdsourced in a Teams thread.' },
  { n: '03', t: 'Audience Intelligence', d: 'The real language buyers use, mined from where they talk when no one’s watching. It won’t show up in a keyword tool.' },
  { n: '04', t: 'Content Activation', d: 'Content engineered to be extracted and quoted by AI — structured so the dice are loaded in your favor.' },
];
const steps = [
  { t: 'Audience intelligence', d: 'What your buyers actually say and ask.' },
  { t: 'Strategic translation', d: 'Turn that into a plan AI can read.' },
  { t: 'Content activation', d: 'Publish what gets extracted and cited.' },
  { t: 'Monitoring', d: 'Watch what AI says, feed it back in.' },
];
---
<BaseLayout title={SITE.name} description={SITE.description} schemas={[serviceSchema()]}>
  <!-- HERO (cream, subtle dot texture) -->
  <section class="hero tex-cream">
    <div class="container hero__grid">
      <div class="hero__copy" data-reveal="left">
        <p class="subhead">ai changed how people find answers</p>
        <h1>Get cited by AI.<br />Not just ranked.</h1>
        <p class="hero__lede">
          Right now AI is telling people what your brand is — and it’s not
          reading your homepage to do it. It’s pulling from Reddit, reviews and
          random third-party pages you’ve never seen. I make sure that when
          someone asks AI about your category, your brand is the answer it
          actually cites.
        </p>
        <div class="hero__ctas">
          <a class="button" href={CTA.calendly}>Book a call</a>
          <a class="button button--ghost" href={CTA.newsletter}>Subscribe to Cited</a>
        </div>
      </div>
      <div class="hero__media" data-reveal="right">
        <FramedPhoto src="/images/laura-3.jpg" alt={`${PERSON.name}, ${PERSON.jobTitle}`} shape="oval" />
        <img class="hero__sticker" src="/brand/assets/sticker-certified-organic.svg" alt="" aria-hidden="true" />
      </div>
    </div>
  </section>

  <!-- MARQUEE (rust, moving) -->
  <div class="band--marquee section--rust marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...marquee, ...marquee].map((m, i) => (
        <>
          <span>{m}</span><span class="marquee__dot">✦</span>
        </>
      ))}
    </div>
  </div>

  <!-- STAT BLOCK (forest, animated numbers) -->
  <section class="band section--forest">
    <div class="container">
      <div class="prose" data-reveal>
        <p class="subhead">here’s the uncomfortable part</p>
        <h2>AI doesn’t build your brand from your website</h2>
        <p>
          It builds it from the ENTIRE internet — reviews, forums, Reddit threads,
          comparison pages, stuff you didn’t write or approve. You can rank #1 on
          Google and still be invisible in the answer. Different game, different work.
        </p>
      </div>
      <div class="stat-grid">
        <div data-reveal data-reveal-delay="1">
          <div class="stat__num"><span data-count="85" data-suffix="%">85%</span></div>
          <p class="stat__label">of brand mentions in AI answers come from third-party pages — not your site.</p>
        </div>
        <div data-reveal data-reveal-delay="2">
          <div class="stat__num"><span data-count="35" data-suffix="%">35%</span></div>
          <p class="stat__label">more organic clicks for brands cited in AI Overviews <span class="cite">(Seer Interactive, Sept 2025)</span>.</p>
        </div>
        <div data-reveal data-reveal-delay="3">
          <div class="stat__num"><span data-count="91" data-suffix="%">91%</span></div>
          <p class="stat__label">more paid clicks for those same cited brands, on the same query.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES (olive textured, numbered cards) -->
  <section class="band tex-olive section--olive">
    <div class="container">
      <div data-reveal>
        <p class="subhead">what i actually do</p>
        <h2>AI visibility &amp; strategy</h2>
      </div>
      <div class="cards">
        {services.map((s, i) => (
          <div class="card" data-reveal data-reveal-delay={String(i % 4)}>
            <span class="card__n">{s.n}</span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        ))}
      </div>
      <p data-reveal><a class="button button--ghost" href="/services">See how it works</a></p>
    </div>
  </section>

  <!-- THE LOOP (cream textured, step progression) -->
  <section class="band tex-cream">
    <div class="container">
      <div class="prose" data-reveal>
        <p class="subhead">the framework</p>
        <h2>The AI Intelligence Loop</h2>
        <p>
          Most agencies skip straight to producing content and hope it lands. I run
          a loop instead — and it compounds. That’s the whole point.
        </p>
      </div>
      <div class="steps">
        {steps.map((s, i) => (
          <div class="step" data-reveal data-reveal-delay={String(i % 4)}>
            <span class="step__n">{i + 1}</span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ANSWER VS CITATION (rust, pull-quote, asymmetric) -->
  <section class="band section--rust">
    <div class="container answer-grid">
      <p class="pullquote" data-reveal="left">Being the answer and being the cited source are two different things.</p>
      <div class="prose" data-reveal="right">
        <p>
          I’ve had clients AI knew cold — named in any category prompt — but every
          citation pointed to a directory they had zero control over. A few months
          of foundation work later, one client’s own domain became the #1 cited
          source for their category, with a 450% jump in how often AI pulled from a
          single retrofitted page.
        </p>
        <p>You can’t guarantee a citation. You CAN load the dice.</p>
        <a class="button" href={CTA.calendly}>Let’s load your dice</a>
      </div>
    </div>
  </section>

  <!-- CITED NEWSLETTER (peach gingham, framed circle) -->
  <section class="band section--peach cited-band">
    <div class="container cited">
      <div data-reveal="left">
        <p class="subhead">my newsletter</p>
        <h2>Cited</h2>
        <p>
          AI changed how customers find answers. Most brand &amp; agency strategies
          haven’t — here’s what to do about it. Real audits, real numbers, no
          recycled 2024 advice.
        </p>
        <a class="button" href={CTA.newsletter}>Subscribe to Cited</a>
      </div>
      <FramedPhoto src="/images/laura-2.jpg" alt="Laura at home" shape="circle" reveal delay="1" />
    </div>
  </section>

  <!-- FINAL CTA (forest) -->
  <section class="band section--forest">
    <div class="container prose final" data-reveal="scale">
      <img class="badge" src="/brand/logo/badge-green.svg" alt="" aria-hidden="true" width="84" height="84" />
      <p class="subhead">featured speaker · cincy ai week</p>
      <h2>Want your brand cited by AI by Q3?</h2>
      <p>That’s the work. Let’s talk about it.</p>
      <div class="hero__ctas">
        <a class="button" href={CTA.calendly}>Book a call</a>
        <a class="button button--ghost" href="/blog">Read the blog</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding-block: var(--space-5) var(--space-5); }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--space-5);
    align-items: center;
  }
  .hero h1 { margin-block: var(--space-1) var(--space-2); }
  .hero__lede { font-size: var(--text-lg); max-width: 46ch; }
  .hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-3); }
  .hero__media { position: relative; }
  .hero__sticker {
    position: absolute; bottom: -22px; left: -22px;
    width: 124px; height: auto; rotate: -8deg; z-index: 2;
  }

  .band { padding-block: var(--space-5); }
  .band--marquee { padding-block: var(--space-2); }
  .cite { font-size: 0.82em; opacity: 0.85; }

  /* Numbered service cards */
  .cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); margin-block: var(--space-3); }
  .card {
    background: var(--cream); color: var(--brown);
    border-radius: 14px; padding: var(--space-3);
    box-shadow: var(--shadow-card);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .card:hover { transform: translateY(-5px); box-shadow: var(--shadow-soft); }
  .card__n { font-family: var(--font-heading); font-size: var(--text-xl); color: var(--olive); }
  .card h3 { margin: 0.2rem 0 0.4rem; color: var(--rust); }
  .card p { margin-bottom: 0; color: var(--brown); }

  /* Answer / pull-quote */
  .answer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); align-items: center; }

  /* Cited */
  .cited-band { background: var(--peach) url('/brand/patterns/pattern-peach.jpg') center / 320px repeat; }
  .cited { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-4); align-items: center; }
  .cited :global(.framed) { max-width: 340px; justify-self: center; }

  .final { text-align: center; max-width: none; }
  .final .hero__ctas { justify-content: center; }
  .final .badge { margin: 0 auto var(--space-2); }

  @media (max-width: 760px) {
    .hero__grid, .cards, .answer-grid, .cited { grid-template-columns: 1fr; }
    .hero__media { order: -1; }
    .cited :global(.framed) { order: -1; }
  }
</style>
