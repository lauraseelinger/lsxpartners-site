---
import BaseLayout from '../layouts/BaseLayout.astro';
import StitchDivider from '../components/StitchDivider.astro';
import LoopDiagram from '../components/LoopDiagram.astro';
import DefinitionBlock from '../components/DefinitionBlock.astro';
import { serviceSchema } from '../lib/schema';
import { targetQuarter } from '../lib/dates';
import { SITE, PERSON, CTA, ENGAGEMENTS } from '../consts';

const quarter = targetQuarter(); // ~4–5 months out, recomputed each build

// HOME — image-forward (full-bleed photos + text overlays), varied blocks,
// motion. Modeled on the structure of the current lsxpartners.com but in the
// new brand. Voice: Full LinkedIn Laura. Stats are her own sourced figures.
const marquee = ['ai visibility', 'get cited by ai', 'aeo', 'geo', 'audience intelligence', 'content activation'];
---
<BaseLayout title={SITE.name} description={SITE.description} schemas={[serviceSchema()]}>
  <!-- HERO — full-bleed photo, text over image -->
  <section class="hero media-overlay media-overlay--hero">
    <img class="bg" src="/images/hero-cropped.jpg" alt="" aria-hidden="true" style="object-position: 42% 38%;" />
    <div class="container hero__inner">
      <p class="subhead">ai visibility &amp; strategy</p>
      <h1>Get cited by AI.<br />Not just ranked.</h1>
      <p class="hero__lede">
        AI is already telling people what your brand is — and it’s not reading
        your homepage to do it. I make sure that when someone asks AI about your
        category, your brand is the answer it actually cites.
      </p>
      <div class="ctas">
        <a class="button" href={CTA.calendly}>Book a call</a>
        <a class="button button--ghost" href={CTA.newsletter}>Subscribe to Cited</a>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="band--marquee section--rust marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...marquee, ...marquee].map((m) => (<><span>{m}</span><span class="marquee__dot">✦</span></>))}
    </div>
  </div>

  <!-- STATS (forest, animated) -->
  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal>
        <p class="subhead">here’s the uncomfortable part</p>
        <h2>AI doesn’t build your brand from your website</h2>
        <p>
          It builds it from the ENTIRE internet — reviews, forums, Reddit threads,
          comparison pages, stuff you didn’t write or approve. You can rank #1 on
          Google and still be invisible in the answer.
        </p>
      </div>
      <div class="stat-grid">
        <div data-reveal data-reveal-delay="1">
          <div class="stat__num"><span data-count="85" data-suffix="%">85%</span></div>
          <p class="stat__label">of brand mentions in AI answers come from third-party pages — not your site.</p>
        </div>
        <div data-reveal data-reveal-delay="2">
          <div class="stat__num"><span data-count="35" data-suffix="%">35%</span></div>
          <p class="stat__label">more organic clicks for brands cited in AI Overviews <span class="cite">(Seer Interactive, 2025)</span>.</p>
        </div>
        <div data-reveal data-reveal-delay="3">
          <div class="stat__num"><span data-count="91" data-suffix="%">91%</span></div>
          <p class="stat__label">more paid clicks for those same cited brands, on the same query.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IS AI VISIBILITY — front-loaded definitional answer (DefinedTerm schema) -->
  <section class="band">
    <div class="container" data-reveal>
      <DefinitionBlock
        term="AI visibility"
        definition="AI visibility is whether — and how — AI engines like ChatGPT, Claude, Gemini, Perplexity and Google AI Overviews surface and cite your brand when people ask questions in your category. It’s distinct from search ranking: you can rank well on Google and still be missing, or uncited, in the AI answer itself."
      />
    </div>
  </section>

  <StitchDivider bg="olive" stitch="ivory" />
  <!-- SERVICES (olive textured, numbered grid) -->
  <section class="band tex-olive section--olive">
    <div class="container">
      <div class="measure" data-reveal>
        <p class="subhead">ways to work with me</p>
        <h2>Pick your entry point</h2>
      </div>
      <div class="cards">
        {ENGAGEMENTS.map((e, i) => (
          <a class="card card--link" href={`/services/${e.slug}`} data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <p class="subhead">{e.eyebrow}</p>
            <h3>{e.name}</h3>
            <p>{e.summary}</p>
            <span class="card__go">Learn more →</span>
          </a>
        ))}
      </div>
      <p data-reveal><a class="button button--ghost" href="/services">See all services</a></p>
    </div>
  </section>

  <!-- FULL-BLEED IMAGE BANNER — text over photo -->
  <section class="band media-overlay media-overlay--center banner">
    <img class="bg" src="/images/laura-laptop-wide.jpg" alt="" aria-hidden="true" />
    <div class="container measure measure--center" data-reveal="scale">
      <p class="subhead">the distinction nobody makes</p>
      <h2>Being the answer and being the cited source are two different things</h2>
      <p>
        I’ve had clients AI knew cold — but every citation pointed to a directory
        they didn’t control. A few months of foundation work later, their own
        domain became the #1 cited source for their category. You can’t guarantee
        a citation. You CAN load the dice.
      </p>
      <a class="button" href={CTA.calendly}>Let’s load your dice</a>
    </div>
  </section>

  <StitchDivider bg="cream" stitch="rust" />
  <!-- THE LOOP (cream textured, visualized) -->
  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-4)">
        <p class="subhead">the framework</p>
        <h2>The AI Intelligence Loop</h2>
        <p>Most agencies skip to producing content and hope it lands. I run a loop instead, and it compounds.</p>
      </div>
      <div data-reveal>
        <LoopDiagram />
      </div>
    </div>
  </section>

  <StitchDivider bg="cream-deep" stitch="rust" />
  <!-- CITED — split: photo blends into the text half (readable solid bg) -->
  <section class="split-feature">
    <img class="split-feature__img" src="/images/hero-couch.jpg" alt="Laura Seelinger" />
    <div class="container">
      <div class="split-feature__text" data-reveal="left">
        <p class="subhead">my newsletter</p>
        <h2>Cited</h2>
        <p>
          AI changed how customers find answers. Most brand &amp; agency strategies
          haven’t — here’s what to do about it. Real audits, real numbers, no
          recycled 2024 advice.
        </p>
        <a class="button" href={CTA.newsletter}>Subscribe to Cited</a>
      </div>
    </div>
  </section>

  <StitchDivider bg="forest" stitch="yellow" />
  <!-- FINAL CTA (forest) -->
  <section class="band section--forest">
    <div class="container measure measure--center final" data-reveal="scale">
      <img class="badge" src="/brand/logo/badge-ivory.svg" alt="" aria-hidden="true" width="84" height="84" />
      <p class="subhead">featured speaker · cincy ai week</p>
      <h2>Want your brand cited by AI by {quarter}?</h2>
      <p>That’s the work. Let’s talk about it.</p>
      <div class="ctas">
        <a class="button" href={CTA.calendly}>Book a call</a>
        <a class="button button--ghost" href="/blog">Read the blog</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero { display: flex; align-items: center; min-height: clamp(440px, 64vh, 600px); padding-block: var(--space-6); }
  .hero__inner { max-width: 760px; }
  .hero h1 { font-size: clamp(2.8rem, 1.8rem + 5vw, 5.5rem); margin-block: var(--space-1) var(--space-2); }
  .hero__lede { font-size: var(--text-lg); max-width: 48ch; }

  .ctas { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-3); }

  .band { padding-block: var(--space-6); }
  .band--marquee { padding-block: var(--space-2); }
  .measure { max-width: 44rem; }
  .measure--center { margin-inline: auto; text-align: center; }
  .measure--center .ctas { justify-content: center; }
  .cite { font-size: 0.82em; opacity: 0.85; }

  .banner { min-height: 60vh; display: flex; align-items: center; }

  /* Service cards — responsive auto-fit grid (3–4 across) */
  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: var(--space-3); margin-block: var(--space-4); }
  .card {
    background: var(--cream); color: var(--brown);
    border-radius: 16px; padding: var(--space-3);
    box-shadow: var(--shadow-card);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow-soft); }
  .card--link { text-decoration: none; display: flex; flex-direction: column; }
  .card h3 { margin: 0.2rem 0 0.4rem; color: var(--rust); }
  .card p { margin-bottom: var(--space-2); color: var(--brown); }
  .card__go { margin-top: auto; color: var(--olive); font-weight: 600; font-size: var(--text-sm); }

  /* Cited — feature split: image fills the right half and feathers into the
     solid (readable) left half where the text lives. */
  .split-feature {
    position: relative;
    overflow: hidden;
    background: var(--cream-deep);
  }
  .split-feature__img {
    position: absolute; top: 0; right: 0;
    width: 50%; height: 100%;
    object-fit: cover; object-position: center 30%;
    -webkit-mask-image: linear-gradient(to left, #000 58%, transparent 100%);
    mask-image: linear-gradient(to left, #000 58%, transparent 100%);
  }
  .split-feature .container { position: relative; z-index: 2; }
  .split-feature__text {
    max-width: 44ch;
    padding-block: var(--space-6);
  }

  .final .badge { margin: 0 auto var(--space-2); }

  @media (max-width: 760px) {
    .hero { min-height: 54vh; }
    .split-feature__img {
      position: relative; width: 100%; height: 260px;
      -webkit-mask-image: linear-gradient(to top, #000 62%, transparent 100%);
      mask-image: linear-gradient(to top, #000 62%, transparent 100%);
    }
    .split-feature__text { padding-block: var(--space-4); }
  }
</style>
