---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import PhotoStack from '../components/PhotoStack.astro';
import StitchDivider from '../components/StitchDivider.astro';
import StartFinder from '../components/StartFinder.astro';
import { serviceSchema } from '../lib/schema';
import { ENGAGEMENTS, CTA } from '../consts';

// SERVICES HUB — premium, big-brand-first. Full-bleed hero, flagship feature,
// engagement grid linking to sub-pages, the Loop, FAQ. No pricing (by scope).
const flagship = ENGAGEMENTS.find((e) => e.flagship)!;
const others = ENGAGEMENTS.filter((e) => !e.flagship);
const faqs = [
  { question: 'Isn’t AI visibility just SEO with a new name?', answer: 'Partly, and that’s the nuance that matters. AI answers are built on top of search indexes, so good SEO still helps — on tight engines like Claude (which leans on Brave) it gets you most of the way. But looser engines like ChatGPT weight structure, earned media and third-party authority differently, so ranking isn’t enough. Knowing which lever each engine pulls is the actual work.' },
  { question: 'Do I need an AI visibility tool?', answer: 'A tool tells you the score. It won’t tell you what to do about it. I use the tools (and test new ones constantly), but the value is the strategy: reading your current AI brand identity, finding the openings, and deciding what to amplify. That’s not something a dashboard does.' },
  { question: 'How is this different from SEO?', answer: 'SEO gets you ranked in a list of links; AI visibility gets you quoted in the answer. They run in the same strategy — you can rank #1 on Google and still be invisible, or uncited, in AI answers.' },
  { question: 'Is it too early to invest in this?', answer: 'The audience-conversation layer — what real buyers say and ask — is durable now; you don’t have to wait for the models to settle. And citations move faster than SEO rankings, so the ground you take early compounds.' },
  { question: 'Do you work with brands or agencies?', answer: 'Both. Brands hire me directly to come in and get their AI visibility together; agencies bring me in as an embedded, often white-labeled, strategy partner. Same caliber of work either way.' },
  { question: 'What does it cost?', answer: 'Engagements are scoped to the brand and the goal, from a one-time audit to the one-month Intensive. The fastest way to a real number is a short call.' },
];
---
<BaseLayout
  title="Services"
  description="AI visibility audits, strategy, and a one-month intensive to get your brand cited by AI — for brands and agencies."
  schemas={[serviceSchema()]}
>
  <!-- HERO -->
  <section class="hero media-overlay media-overlay--hero">
    <img class="bg" src="/images/services-hero.jpg" alt="" aria-hidden="true" style="object-position: center 28%;" />
    <div class="container hero__inner">
      <p class="subhead">ai visibility &amp; strategy</p>
      <h1>Bring me in. I’ll get your AI visibility together.</h1>
      <p class="hero__lede">
        Whether you need a one-month intensive to fix it now, a blueprint for a
        rebuild, or an ongoing partner — the goal is the same: when AI talks about
        your category, your brand is the answer it cites. For brands and agencies.
      </p>
      <a class="button" href={CTA.calendly}>Book a call</a>
    </div>
  </section>

  <!-- FLAGSHIP FEATURE (rust color block — breaks the hero->image adjacency) -->
  <StitchDivider bg="rust" stitch="ivory" />
  <section class="band section--rust flagship">
    <div class="container flagship__grid">
      <div data-reveal="left">
        <p class="subhead">{flagship.eyebrow}</p>
        <h2>{flagship.name}</h2>
        <p class="flagship__tag">{flagship.tagline}</p>
        <p>{flagship.summary}</p>
        <details class="eng-topics eng-topics--dark">
          <summary>What’s included</summary>
          <ul>{flagship.topics.map((t) => <li>{t}</li>)}</ul>
        </details>
        <a class="button" href={`/services/${flagship.slug}`}>Explore the Intensive →</a>
      </div>
      <PhotoStack src="/images/laura-2.jpg" alt="Laura Seelinger" ratio="3 / 4" reveal delay="1" />
    </div>
  </section>

  <!-- ENGAGEMENT GRID -->
  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal>
        <p class="subhead">ways to work together</p>
        <h2>Pick your entry point</h2>
      </div>
      <div class="eng-grid">
        {others.map((e, i) => (
          <div class="eng-card" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <p class="subhead">{e.eyebrow}</p>
            <h3>{e.name}</h3>
            <p class="eng-card__sum">{e.summary}</p>
            <details class="eng-topics">
              <summary>What’s included</summary>
              <ul>{e.topics.map((t) => <li>{t}</li>)}</ul>
            </details>
            <a class="eng-card__go" href={`/services/${e.slug}`}>Full details →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- START FINDER — loud, interactive "where should you start?" -->
  <StitchDivider bg="blue" stitch="brown" />
  <section class="band finder-band">
    <div class="container">
      <div class="finder-band__head" data-reveal>
        <p class="subhead">two quick questions</p>
        <h2>Where should you even start?</h2>
      </div>
      <div class="finder-band__wrap" data-reveal>
        <div class="finder-doodle" aria-hidden="true">
          <span class="finder-callout">tell me where you fall &amp; I’ll point you to the right starting point</span>
          <svg class="finder-arrow" viewBox="0 0 120 130" fill="none">
            <path d="M14 14 C 64 16 96 40 82 80 C 78 94 80 104 78 118" stroke="var(--brown)" stroke-width="5" stroke-linecap="round"/>
            <path d="M64 104 L79 121 L94 104" stroke="var(--brown)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <StartFinder />
      </div>
    </div>
  </section>

  <!-- HOW THE WORK RUNS — text treatment (the visual loop lives on the home page) -->
  <section class="band section--forest">
    <div class="container measure" data-reveal>
      <p class="subhead">how the work runs</p>
      <h2>Every engagement runs the same method</h2>
      <p>
        It’s built on my AI Intelligence Loop: audience intelligence feeds the
        strategy, the strategy drives what gets published, monitoring tells us what
        AI does with it — and that learning feeds the next round. The longer we work
        together, the sharper it gets.
      </p>
      <p><a href="/blog/ai-intelligence-loop">See how the loop works →</a></p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="band">
    <div class="container">
      <FAQ items={faqs} />
      <p style="margin-top: var(--space-4)"><a class="button" href={CTA.calendly}>Let’s talk AI visibility</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { display: flex; align-items: center; min-height: 78vh; padding-block: var(--space-6); --hero-fade-to: var(--rust); }
  .hero__inner { max-width: 780px; }
  .hero h1 { font-size: clamp(2.6rem, 1.8rem + 4.5vw, 5rem); margin-block: var(--space-1) var(--space-2); }
  .hero__lede { font-size: var(--text-lg); max-width: 52ch; margin-bottom: var(--space-3); }

  .band { padding-block: var(--space-6); }
  .measure { max-width: 44rem; }

  /* Flagship — rust color band with a blended photo */
  .flagship__grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-5); align-items: center; }
  .flagship__grid > div { max-width: 48ch; }
  .flagship__tag { font-size: var(--text-lg); }
  .flagship :global(.pstack) { max-width: 340px; justify-self: center; }

  /* Engagement cards */
  .eng-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-3); margin-top: var(--space-4); }
  .eng-card {
    display: flex; flex-direction: column; color: var(--brown);
    background: var(--cream); border-radius: 16px; padding: var(--space-3);
    box-shadow: var(--shadow-card);
  }
  .eng-card h3 { color: var(--rust); margin: 0.2rem 0 0.4rem; }
  .eng-card__sum { font-size: var(--text-sm); }
  .eng-card__go { margin-top: var(--space-2); color: var(--olive); font-weight: 600; font-size: var(--text-sm); text-decoration: none; }
  .eng-card__go:hover { text-decoration: underline; }

  /* Topics dropdown (native <details>) */
  .eng-topics { margin: var(--space-1) 0; }
  .eng-topics summary {
    cursor: pointer; font-weight: 600; font-size: var(--text-sm);
    color: var(--rust); list-style: none; padding: 0.4rem 0;
  }
  .eng-topics summary::after { content: ' ▾'; }
  .eng-topics[open] summary::after { content: ' ▴'; }
  .eng-topics ul { margin: 0 0 var(--space-1); padding-left: 1.1em; font-size: var(--text-sm); }
  .eng-topics li { margin-bottom: 0.25rem; }
  /* On the rust flagship band */
  .eng-topics--dark summary { color: var(--cream); }
  .eng-topics--dark ul { color: var(--cream); }

  /* Loud Start Finder band */
  .finder-band { background: var(--blue); }
  .finder-band__head { max-width: 64ch; margin-bottom: var(--space-3); }
  .finder-band .subhead { color: var(--brown); opacity: 0.9; }
  .finder-band h2 { color: var(--brown); font-size: clamp(2.2rem, 1.5rem + 3vw, 3.8rem); }
  .finder-band__hype { font-size: var(--text-lg); color: var(--brown); max-width: 52ch; }
  .finder-band__wrap { position: relative; }
  .finder-doodle { display: flex; align-items: flex-end; justify-content: center; gap: var(--space-2); margin-bottom: -6px; }
  .finder-callout {
    font-family: var(--font-sub); font-weight: 800; font-style: italic; text-transform: lowercase;
    color: var(--cream); background: var(--rust);
    padding: 0.5rem 0.95rem; border-radius: 10px;
    transform: rotate(-3deg); box-shadow: var(--shadow-card);
    font-size: var(--text-lg); line-height: 1.15; max-width: 22ch; text-align: center;
  }
  .finder-arrow { width: 84px; height: auto; flex: none; }
  @media (max-width: 760px) { .finder-doodle { display: none; } }

  @media (max-width: 760px) {
    .flagship__grid { grid-template-columns: 1fr; }
    .flagship :global(.framed) { order: -1; }
    .hero { min-height: 64vh; }
  }
</style>
