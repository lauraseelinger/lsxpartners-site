---
import BaseLayout from '../layouts/BaseLayout.astro';
import HoverReveal from '../components/HoverReveal.astro';
import FramedPhoto from '../components/FramedPhoto.astro';
import StitchDivider from '../components/StitchDivider.astro';
import { eventSchema } from '../lib/schema';
import { CTA } from '../consts';

// SPEAKING — image-forward, color-blocked, with the hover-reveal pattern for
// talk topics. Photos are from Cincy AI Week (on stage).
const topics = [
  { title: 'What AI actually thinks about your brand', blurb: 'I pull up a real brand live and show the room what ChatGPT, Claude, Gemini and Perplexity say about it — and where those citations are really coming from. It lands every time.' },
  { title: 'Owning the answer vs. owning the citation', blurb: 'Getting named by AI and getting credited as the source take different work. I break down how a brand wins both, with real before-and-after numbers.' },
  { title: 'The audience intelligence most brands skip', blurb: 'Where real buyer language actually lives, why keyword tools miss it, and how that same insight becomes your content and your AI visibility strategy at once.' },
  { title: 'The lo-fi / analog pendulum', blurb: 'Why the swing back to real, human, un-AI’d content is a strategic opening for brands paying attention — and how to use it without looking like everyone else.' },
  { title: 'Auditing your own AI visibility', blurb: 'The step-by-step process I run for clients, walked through so your team leaves with a plan they can start Monday, not a notebook of inspiration.' },
];
const talks = [
  {
    event: 'Cincy AI Week',
    title: 'AI Visibility Audit: What AI Thinks About Your Brand',
    track: 'AI for Marketing, Sales & Operations',
    dateDisplay: 'June 2026',
    startISO: '2026-06-10T14:30:00-04:00',
    venue: 'Union Hall', city: 'Cincinnati, OH',
    description: 'A live look at what AI engines actually say about a brand — the gaps most brands don’t know they have, and the difference between owning the answer and owning the citation.',
    url: '',
  },
  {
    event: 'Atlanta AI Week',
    title: 'How AI Is Rewriting Search and What It Means for Your Brand',
    track: 'AI in Action',
    dateDisplay: 'April 2026',
    startISO: '2026-04-21T13:30:00-04:00',
    venue: 'Roam Forum', city: 'Atlanta, GA',
    description: 'AI-powered search, answer engines and conversational interfaces are rewriting how brands get discovered. A workshop on keeping — and growing — brand visibility in the AI search era.',
    url: '',
  },
  {
    event: 'Eastern Illinois University',
    title: 'Sales Is Love Conference',
    track: 'Guest speaker',
    dateDisplay: 'May 2026',
    startISO: '2026-05-01T09:00:00-05:00',
    venue: 'Tarble Museum of Art', city: 'Charleston, IL',
    description: 'A guest session on AI visibility at EIU’s student-run sales conference — built on the idea that the best sales feel like service, not pressure.',
    url: 'https://www.eiu.edu/calendar/event.php?id=15665',
  },
  {
    event: 'Bowling Green State University',
    title: 'Guest session',
    track: 'Guest speaker',
    dateDisplay: 'February 2026',
    startISO: '2026-02-01T00:00:00-05:00',
    venue: '', city: 'Bowling Green, OH',
    description: 'A guest session with BGSU students and founders on getting found — and cited — by AI.',
    url: '',
  },
  {
    event: 'Great Lakes AI Week',
    title: 'Implementing AI into your processes — for real',
    track: 'Workshop',
    dateDisplay: 'November 2025',
    startISO: '2025-11-01T00:00:00-04:00',
    venue: '', city: '',
    description: 'I reviewed how marketers can begin to implement AI into their processes in a real, meaningful way.',
    url: '',
  },
  {
    event: 'Chamber Amplified',
    title: 'Findlay Chamber of Commerce podcast',
    titleUrl: 'https://www.findlayhancockchamber.com/',
    track: 'Podcast',
    dateDisplay: '',
    startISO: '',
    venue: '', city: 'Findlay, OH',
    description: 'A conversation on AI visibility — what it means for local businesses and the chambers that serve them.',
    url: 'https://podcasts.apple.com/us/podcast/chamber-amplified/id1612666890',
    linkLabel: 'Listen to the episode →',
  },
];
---
<BaseLayout
  title="Speaking"
  description="Laura Seelinger speaks on AI visibility, GEO, and AEO — practical, no-fluff talks and workshops for marketing teams, agencies, and events."
  schemas={talks.filter((t) => t.startISO).map((t) => eventSchema(t))}
>
  <!-- HERO -->
  <section class="hero media-overlay media-overlay--hero">
    <img class="bg" src="/images/speaking-stage-wide.jpg" alt="" aria-hidden="true" style="object-position: center 35%;" />
    <div class="container hero__inner">
      <p class="subhead">speaking &amp; workshops</p>
      <h1>Talks people can actually act on</h1>
      <p class="hero__lede">
        My pet peeve is leaving a session fired up with no real plan, so I don’t
        do that to a room. I speak on AI visibility, GEO and AEO — what AI thinks
        about your brand, and exactly what to do about it.
      </p>
      <a class="button" href="/contact?topic=speaking#note">Invite me to speak</a>
    </div>
  </section>

  <!-- INTRO (forest) — split with podium photo -->
  <section class="band section--forest">
    <div class="container intro-split">
      <div data-reveal="left">
        <p class="subhead">why book me</p>
        <h2>I give a room something to actually do</h2>
        <p>
          I run live audits on stage, share the real numbers from client work, and
          send people home with a process they can run themselves. It’s the same
          thing that lights me up about the work: handing people something they can
          action the next morning, while it still feels urgent.
        </p>
      </div>
      <FramedPhoto src="/images/speaking-podium.jpg" alt="Laura presenting at Cincy AI Week" shape="feather" ratio="3 / 4" reveal delay="1" />
    </div>
  </section>

  <!-- TOPICS — hover reveal (cream texture) -->
  <StitchDivider bg="cream" stitch="rust" />
  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">hover any topic to dig in →</p>
        <h2>What I cover</h2>
      </div>
      <div data-reveal>
        <HoverReveal items={topics} />
      </div>
    </div>
  </section>

  <!-- RECENT & UPCOMING TALKS — horizontal carousel on a travel map -->
  <StitchDivider bg="olive" stitch="ivory" />
  <section class="band section--olive travel-map">
    <div class="map-pins" aria-hidden="true">
      {[
        { name: 'Atlanta', x: '40%', y: '66%', lead: true },
        { name: 'Cincinnati', x: '20%', y: '30%' },
        { name: 'Charleston', x: '11%', y: '60%' },
        { name: 'Grand Rapids', x: '72%', y: '32%' },
        { name: 'Bowling Green', x: '60%', y: '52%' },
        { name: 'and counting', x: '87%', y: '74%' },
      ].map((p) => (
        <span class:list={['map-pin', p.lead && 'map-pin--lead']} style={`left:${p.x};top:${p.y}`}>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7z"/><circle cx="12" cy="9" r="2.4"/></svg>
          <span class="map-pin__label">{p.name}</span>
        </span>
      ))}
    </div>
    <div class="container">
      <div class="talks-head" data-reveal>
        <div class="measure">
          <p class="subhead">on stage, on the road</p>
          <h2>Where I’ve been on the mic</h2>
        </div>
        <div class="talks-nav">
          <button type="button" class="tnav" data-dir="-1" aria-label="Previous">‹</button>
          <button type="button" class="tnav" data-dir="1" aria-label="Next">›</button>
        </div>
      </div>
      <div class="talks" id="talks-track">
        {talks.map((t) => (
          <article class="talk">
            <h3>{t.event}</h3>
            <p class="talk__title">{t.titleUrl ? <a class="talk__titlelink" href={t.titleUrl}>{t.title}</a> : t.title}</p>
            {(t.dateDisplay || t.city) && (
              <p class="talk__meta">{[t.dateDisplay, t.city].filter(Boolean).join(' · ')}</p>
            )}
            <p class="talk__desc">{t.description}</p>
            {t.url && <a class="talk__link" href={t.url}>{t.linkLabel ?? 'Event details →'}</a>}
          </article>
        ))}
      </div>
      <p class="also" data-reveal>Also: private brand &amp; agency workshops, panels, and more.</p>
    </div>
  </section>

  <script>
    document.querySelectorAll('.talks-nav').forEach((nav) => {
      const track = document.getElementById('talks-track');
      nav.querySelectorAll('button').forEach((btn) =>
        btn.addEventListener('click', () => {
          const dir = Number(btn.getAttribute('data-dir'));
          if (track) track.scrollBy({ left: dir * 330, behavior: 'smooth' });
        })
      );
    });
  </script>

  <!-- CTA (forest) -->
  <StitchDivider bg="forest" stitch="yellow" />
  <section class="band section--forest">
    <div class="container measure measure--center" data-reveal="scale">
      <h2>Got a stage? Let’s talk.</h2>
      <p>Events, team workshops, podcasts — if your audience needs to get AI visibility, I’m in.</p>
      <a class="button" href="/contact?topic=speaking#note">Invite me to speak</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { display: flex; align-items: center; min-height: 72vh; padding-block: var(--space-6); --hero-fade-to: var(--forest); }
  .hero__inner { max-width: 760px; }
  .hero h1 { font-size: clamp(2.6rem, 1.8rem + 4vw, 4.8rem); margin-block: var(--space-1) var(--space-2); }
  .hero__lede { font-size: var(--text-lg); max-width: 50ch; margin-bottom: var(--space-3); }

  .band { padding-block: var(--space-6); }
  .measure { max-width: 44rem; }
  .measure--center { margin-inline: auto; text-align: center; }

  /* Intro split (forest + photo) */
  .intro-split { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-5); align-items: center; }
  .intro-split > div { max-width: 56ch; }
  .intro-split :global(.framed) { max-width: 340px; justify-self: center; }

  /* Travel-map background — reads as "she's been all over" */
  .travel-map { position: relative; overflow: hidden; }
  .travel-map > .container { position: relative; z-index: 2; }
  .map-pins { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  .map-pin { position: absolute; transform: translate(-50%, -100%); display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .map-pin svg { width: 16px; height: 16px; fill: rgba(252, 245, 229, 0.26); }
  .map-pin__label {
    font-family: var(--font-sub); font-style: italic; font-weight: 800;
    font-size: var(--text-sm); color: rgba(252, 245, 229, 0.18);
    white-space: nowrap; letter-spacing: 0.02em;
  }
  /* Atlanta reads as the marquee stop */
  .map-pin--lead svg { width: 30px; height: 30px; fill: var(--peach); }
  .map-pin--lead .map-pin__label { color: var(--peach); font-size: var(--text-lg); }
  @media (max-width: 760px) { .map-pins { display: none; } }
  .travel-map {
    background:
      radial-gradient(circle at 16% 28%, rgba(252, 245, 229, 0.16) 0 11%, transparent 30%),
      radial-gradient(circle at 82% 66%, rgba(163, 187, 195, 0.28) 0 12%, transparent 32%),
      radial-gradient(circle at 60% 20%, rgba(255, 190, 159, 0.22) 0 8%, transparent 24%),
      linear-gradient(rgba(252, 245, 229, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(252, 245, 229, 0.1) 1px, transparent 1px),
      var(--olive);
    background-size: auto, auto, auto, 28px 28px, 28px 28px, auto;
  }

  /* Talk carousel (horizontal scroll; 2 cards live off-screen) */
  .talks-head { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-2); margin-bottom: var(--space-3); }
  .talks-nav { display: flex; gap: 0.5rem; flex: none; }
  .tnav { width: 2.6rem; height: 2.6rem; border-radius: 50%; border: 2px solid var(--cream); background: transparent; color: var(--cream); font-size: 1.4rem; line-height: 1; cursor: pointer; transition: background 0.15s, color 0.15s; }
  .tnav:hover { background: var(--cream); color: var(--rust); }
  .talks { display: flex; gap: var(--space-3); overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding-bottom: var(--space-2); scrollbar-width: none; }
  .talks::-webkit-scrollbar { display: none; }
  .talk { flex: 0 0 300px; scroll-snap-align: start; background: var(--cream); color: var(--brown); border-radius: 16px; padding: var(--space-3); box-shadow: var(--shadow-card); }
  .talk__track { font-family: var(--font-sub); font-weight: 800; font-style: italic; color: var(--olive); font-size: var(--text-sm); margin-bottom: var(--space-1); }
  .talk h3 { color: var(--rust); margin: 0 0 0.1rem; font-size: var(--text-lg); }
  .talk__title { font-weight: 600; color: var(--brown); margin: 0 0 var(--space-1); }
  /* override the section--olive "links go cream" rule — these sit on a cream card */
  .talk a.talk__titlelink { color: var(--brown); text-decoration: underline; text-decoration-color: var(--rust); text-underline-offset: 2px; }
  .talk a.talk__titlelink:hover { color: var(--rust); }
  .talk__meta { font-size: var(--text-sm); font-weight: 600; color: var(--olive); margin-bottom: var(--space-1); }
  .talk__desc { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-1); }
  .talk__link { font-size: var(--text-sm); font-weight: 600; color: var(--olive); }
  .also { margin-top: var(--space-4); font-size: var(--text-sm); }
  .also a { color: var(--cream); text-decoration: underline; font-weight: 600; }

  @media (max-width: 760px) {
    .intro-split { grid-template-columns: 1fr; }
    .intro-split :global(.framed) { order: -1; }
  }
</style>
