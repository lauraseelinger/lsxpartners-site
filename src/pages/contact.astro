---
import BaseLayout from '../layouts/BaseLayout.astro';
import StitchDivider from '../components/StitchDivider.astro';
import { PERSON, CTA } from '../consts';

// Web3Forms handles the form POST (no backend on a static site). Get a free
// access key at https://web3forms.com (enter laura@lsxpartners.com — the key is
// tied to that inbox; submissions email straight there). Paste it below.
const WEB3FORMS_KEY = 'f6e0cacd-4505-4445-a6c4-06acc46e10c7';

// CONTACT — image-forward, color-blocked. Primary = Calendly; also email,
// LinkedIn, and the Cited newsletter. Voice: Full LinkedIn Laura.
// (No marketing-guru fluff — see laura-no-guru-fluff memory.)
const methods = [
  {
    key: 'call', label: 'Book a call', value: '20 minutes · Zoom · no slides',
    href: CTA.calendly,
    icon: '<rect x="3" y="5" width="18" height="16" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/>',
  },
  {
    key: 'linkedin', label: 'Connect on LinkedIn', value: '@lseelinger',
    href: PERSON.sameAs[0],
    icon: '<rect x="3" y="3" width="18" height="18" rx="3"/><line x1="8" y1="10" x2="8" y2="16"/><circle cx="8" cy="7" r="1"/><path d="M12 16v-3a2 2 0 0 1 4 0v3"/><line x1="12" y1="10" x2="12" y2="16"/>',
  },
  {
    key: 'cited', label: 'Subscribe to Cited', value: 'the AI-visibility newsletter',
    href: CTA.newsletter,
    icon: '<path d="M4 19V5a1 1 0 0 1 1-1h11l4 4v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z"/><line x1="8" y1="9" x2="14" y2="9"/><line x1="8" y1="13" x2="16" y2="13"/>',
  },
];
---
<BaseLayout
  title="Contact"
  description="Work with LSX Partners on AI visibility and strategy — book a 20-minute call with Laura Seelinger, or send a note to get started."
>
  <!-- HEADER -->
  <section class="band tex-cream">
    <div class="container split">
      <div data-reveal="left">
        <p class="subhead">let's talk</p>
        <h1>Let's find out what AI says about your brand</h1>
        <p class="contact__lede">
          Want to know what AI is telling people about your brand — and how to
          become the source it cites? Grab 20 minutes on my calendar. We'll talk
          through where you stand with AI visibility and where I'd start. Brands
          and agencies both.
        </p>
        <a class="button" href={CTA.calendly}>Book a call</a>
      </div>

      <div class="ccluster" data-reveal>
        <img class="ccluster__photo" src="/images/contact-laura.jpg" alt="Laura Seelinger" />
        <div class="ccluster__wash" aria-hidden="true"></div>
        <img class="cstk cstk--1" src="/brand/assets/sticker-locally-sourced.png" alt="" aria-hidden="true" />
        <img class="cstk cstk--2" src="/brand/assets/sticker-team.png" alt="" aria-hidden="true" />
        <img class="cstk cstk--3" src="/brand/assets/sticker-tailored.png" alt="" aria-hidden="true" />
      </div>
    </div>
  </section>

  <!-- SEND A NOTE (form) -->
  <StitchDivider bg="peach" stitch="rust" />
  <section class="band section--peach" id="note">
    <div class="container fsplit">
      <div class="measure" data-reveal="left">
        <p class="subhead">or send a note</p>
        <h2>Tell me what you're working on</h2>
        <p>
          A speaking invite, a brand that's invisible in AI, or an agency that wants
          the lane covered — give me the gist and I'll come back to you, usually
          within a day or two.
        </p>
      </div>

      <form class="cform" id="contact-form" data-reveal="right">
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="New inquiry from lsxpartners.com" />
        <input type="hidden" name="from_name" value="LSX Partners site" />
        <input type="checkbox" name="botcheck" class="cform__bot" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <label class="cfield">
          <span class="cfield__label">Name</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label class="cfield">
          <span class="cfield__label">Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label class="cfield cfield--full">
          <span class="cfield__label">Company / organization <span class="cfield__opt">(optional)</span></span>
          <input type="text" name="company" autocomplete="organization" />
        </label>
        <label class="cfield cfield--full">
          <span class="cfield__label">What's this about?</span>
          <select name="topic" id="cform-topic">
            <option value="AI visibility for my brand">AI visibility for my brand</option>
            <option value="AI visibility for my agency's clients">AI visibility for my agency's clients</option>
            <option value="Speaking or workshop">Speaking or workshop</option>
            <option value="Something else">Something else</option>
          </select>
        </label>
        <label class="cfield cfield--full">
          <span class="cfield__label">Message</span>
          <textarea name="message" rows="5" required></textarea>
        </label>
        <div class="cform__foot cfield--full">
          <button type="submit" class="button">Send it</button>
          <p class="cform__status" id="cform-status" role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </section>

  <!-- WAYS TO REACH -->
  <StitchDivider bg="cream" stitch="rust" />
  <section class="band section--cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">pick your lane</p>
        <h2>Ways to reach me</h2>
      </div>
      <div class="cmethods">
        {methods.map((m, i) => (
          <a class="cmethod" href={m.href} data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="cmethod__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={m.icon}></svg>
            </span>
            <span class="cmethod__body">
              <span class="cmethod__label">{m.label}</span>
              <span class="cmethod__value">{m.value}</span>
            </span>
            <span class="cmethod__go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <StitchDivider bg="rust" stitch="yellow" />
  <section class="band section--rust">
    <div class="container measure measure--center" data-reveal="scale">
      <h2>Curious where you stand with AI?</h2>
      <p>Book a 20-minute call and we'll talk it through.</p>
      <a class="button button--ghost" href={CTA.calendly}>Book a call</a>
    </div>
  </section>

  <script>
    // Preselect the topic when arriving from a "Invite me to speak" link.
    const params = new URLSearchParams(window.location.search);
    const sel = document.getElementById('cform-topic') as HTMLSelectElement | null;
    if (sel && params.get('topic') === 'speaking') {
      for (const o of Array.from(sel.options)) {
        if (/speaking/i.test(o.value)) { o.selected = true; break; }
      }
    }

    // Submit to Web3Forms via fetch so we can show an inline thank-you.
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('cform-status');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      if (data.get('botcheck')) return; // honeypot tripped
      const btn = form.querySelector('button[type=submit]') as HTMLButtonElement | null;
      if (status) { status.textContent = 'Sending…'; status.classList.remove('is-error'); }
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();
        if (json.success) {
          form.innerHTML =
            '<div class="cform__done"><h3>Got it — thank you.</h3>' +
            '<p>Your note landed in my inbox. I’ll get back to you, usually within a day or two.</p></div>';
        } else {
          throw new Error(json.message || 'failed');
        }
      } catch (err) {
        if (status) {
          status.textContent = 'Something went wrong — please try again, or reach me on LinkedIn.';
          status.classList.add('is-error');
        }
        if (btn) { btn.disabled = false; btn.textContent = 'Send it'; }
      }
    });
  </script>
</BaseLayout>

<style>
  .band { padding-block: var(--space-6); }
  .measure { max-width: 44rem; }
  .measure--center { margin-inline: auto; text-align: center; }
  .split { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-5); align-items: center; }
  .split > div:first-child { max-width: 56ch; }
  .contact__lede { font-size: var(--text-lg); margin-bottom: var(--space-3); }

  /* photo card with a pattern overlay fading down from the top, + stickers
     (the blog-card treatment — no stacked panels) */
  .ccluster { position: relative; width: min(560px, 100%); aspect-ratio: 3 / 2; margin-inline: auto; }
  .ccluster__photo {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    border-radius: 18px; box-shadow: var(--shadow-card); z-index: 1;
  }
  .ccluster__wash {
    position: absolute; inset: 0; border-radius: 18px; z-index: 2; pointer-events: none; overflow: hidden; opacity: 0.5;
    background: linear-gradient(rgba(255,190,159,0.32), rgba(255,190,159,0.32)), url('/brand/patterns/pattern-5.jpg') center / 180px repeat;
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.8) 0, rgba(0,0,0,0.55) 22%, rgba(0,0,0,0.3) 42%, transparent 62%);
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.8) 0, rgba(0,0,0,0.55) 22%, rgba(0,0,0,0.3) 42%, transparent 62%);
  }
  .cstk { position: absolute; z-index: 3; height: auto; filter: drop-shadow(0 6px 12px rgba(58,42,30,0.25)); }
  .cstk--1 { top: -9%; left: -5%; width: 104px; transform: rotate(-10deg); }
  .cstk--2 { bottom: -9%; right: -4%; width: 112px; transform: rotate(8deg); }
  .cstk--3 { top: -8%; right: -6%; width: 80px; transform: rotate(-5deg); }

  /* send-a-note form */
  .fsplit { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: var(--space-5); align-items: start; }
  .fsplit .measure { max-width: 38ch; }
  .cform { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); position: relative; }
  .cfield { display: flex; flex-direction: column; gap: 0.4rem; }
  .cfield--full { grid-column: 1 / -1; }
  .cfield__label { font-family: var(--font-sub); font-style: italic; font-weight: 700; font-size: var(--text-sm); color: var(--brown); }
  .cfield__opt { font-style: normal; font-weight: 400; color: var(--color-text-muted); }
  .cform input, .cform select, .cform textarea {
    font: inherit; font-size: var(--text-base); color: var(--brown);
    background: #fffdf8; border: 2px solid rgba(58, 42, 30, 0.18); border-radius: 12px;
    padding: 0.7rem 0.85rem; width: 100%;
  }
  .cform input:focus, .cform select:focus, .cform textarea:focus { outline: none; border-color: var(--rust); }
  .cform textarea { resize: vertical; min-height: 7rem; }
  .cform__bot { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  .cform__foot { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
  .cform__status { font-size: var(--text-sm); color: var(--color-text-muted); margin: 0; }
  .cform__status.is-error { color: var(--rust); }
  .cform__done h3 { font-family: var(--font-heading); color: var(--rust); margin: 0 0 var(--space-1); }
  .cform__done p { margin: 0; }

  .cmethods { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--space-3); }
  .cmethod {
    display: flex; align-items: center; gap: var(--space-2); text-decoration: none; color: inherit;
    background: var(--cream); border: 2px solid transparent; border-radius: 16px; padding: var(--space-3);
    box-shadow: var(--shadow-card); transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .cmethod:hover { transform: translateY(-3px); border-color: var(--rust); }
  .cmethod__icon { flex: none; display: grid; place-items: center; width: 3rem; height: 3rem; border-radius: 50%; background: var(--rust); color: var(--cream); }
  .cmethod__icon svg { width: 1.5rem; height: 1.5rem; }
  .cmethod__body { display: flex; flex-direction: column; flex: 1; }
  .cmethod__label { font-family: var(--font-heading); font-size: var(--text-lg); color: var(--brown); }
  .cmethod__value { font-size: var(--text-sm); color: var(--color-text-muted); }
  .cmethod__go { color: var(--rust); font-weight: 700; flex: none; }

  @media (max-width: 760px) {
    .split { grid-template-columns: 1fr; }
    .ccluster { order: -1; width: min(320px, 82%); }
    .fsplit { grid-template-columns: 1fr; }
    .cform { grid-template-columns: 1fr; }
    .cmethods { grid-template-columns: 1fr; }
  }
</style>
