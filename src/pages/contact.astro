---
import BaseLayout from '../layouts/BaseLayout.astro';
import StitchDivider from '../components/StitchDivider.astro';
import { PERSON, CTA } from '../consts';

// CONTACT — image-forward, color-blocked. Primary = Calendly; also email,
// LinkedIn, and the Cited newsletter. Voice: Full LinkedIn Laura.
// (No marketing-guru fluff — see laura-no-guru-fluff memory.)
const methods = [
  {
    key: 'call', label: 'Book a call', value: '20 minutes · Zoom · no slides',
    href: CTA.calendly,
    icon: '<rect x="3" y="5" width="18" height="16" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/>',
  },
  {
    key: 'email', label: 'Email me', value: PERSON.email,
    href: `mailto:${PERSON.email}`,
    icon: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/>',
  },
  {
    key: 'linkedin', label: 'Connect on LinkedIn', value: '@lseelinger',
    href: PERSON.sameAs[0],
    icon: '<rect x="3" y="3" width="18" height="18" rx="3"/><line x1="8" y1="10" x2="8" y2="16"/><circle cx="8" cy="7" r="1"/><path d="M12 16v-3a2 2 0 0 1 4 0v3"/><line x1="12" y1="10" x2="12" y2="16"/>',
  },
  {
    key: 'cited', label: 'Subscribe to Cited', value: 'the AI-visibility newsletter',
    href: CTA.newsletter,
    icon: '<path d="M4 19V5a1 1 0 0 1 1-1h11l4 4v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1z"/><line x1="8" y1="9" x2="14" y2="9"/><line x1="8" y1="13" x2="16" y2="13"/>',
  },
];
---
<BaseLayout
  title="Contact"
  description="Work with LSX Partners on AI visibility and strategy. Book a call with Laura Seelinger, or reach out by email or LinkedIn."
>
  <!-- HEADER -->
  <section class="band tex-cream">
    <div class="container split">
      <div data-reveal="left">
        <p class="subhead">let's talk</p>
        <h1>Let's find out what AI says about your brand</h1>
        <p class="contact__lede">
          Want to know what AI is telling people about your brand — and how to
          become the source it cites? Grab 20 minutes on my calendar. On the call
          we'll pull up what ChatGPT, Claude, Gemini and Perplexity actually say
          about you, and I'll tell you what I'd do about it. Brands and agencies
          both.
        </p>
        <a class="button" href={CTA.calendly}>Book a call</a>
      </div>

      <div class="ccluster" data-reveal>
        <div class="ccluster__pat ccluster__pat--back" aria-hidden="true"></div>
        <div class="ccluster__pat ccluster__pat--front" aria-hidden="true"></div>
        <img class="ccluster__photo" src="/images/contact-laura.jpg" alt="Laura Seelinger" />
        <div class="ccluster__wash" aria-hidden="true"></div>
        <img class="cstk cstk--1" src="/brand/assets/sticker-locally-sourced.png" alt="" aria-hidden="true" />
        <img class="cstk cstk--2" src="/brand/assets/sticker-team.png" alt="" aria-hidden="true" />
        <img class="cstk cstk--3" src="/brand/assets/sticker-tailored.png" alt="" aria-hidden="true" />
      </div>
    </div>
  </section>

  <!-- WAYS TO REACH -->
  <StitchDivider bg="cream" stitch="rust" />
  <section class="band section--cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">pick your lane</p>
        <h2>Four ways to reach me</h2>
      </div>
      <div class="cmethods">
        {methods.map((m, i) => (
          <a class="cmethod" href={m.href} data-reveal data-reveal-delay={(i % 4) + 1}>
            <span class="cmethod__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={m.icon}></svg>
            </span>
            <span class="cmethod__body">
              <span class="cmethod__label">{m.label}</span>
              <span class="cmethod__value">{m.value}</span>
            </span>
            <span class="cmethod__go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <StitchDivider bg="rust" stitch="yellow" />
  <section class="band section--rust">
    <div class="container measure measure--center" data-reveal="scale">
      <h2>Want to see what AI says about you right now?</h2>
      <p>Book a call and I'll pull it up live.</p>
      <a class="button button--ghost" href={CTA.calendly}>Book a call</a>
    </div>
  </section>
</BaseLayout>

<style>
  .band { padding-block: var(--space-6); }
  .measure { max-width: 44rem; }
  .measure--center { margin-inline: auto; text-align: center; }
  .split { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-5); align-items: center; }
  .split > div:first-child { max-width: 56ch; }
  .contact__lede { font-size: var(--text-lg); margin-bottom: var(--space-3); }

  /* photo + stacked pattern + stickers cluster (landscape) */
  .ccluster { position: relative; width: min(540px, 100%); aspect-ratio: 3 / 2; margin-inline: auto; }
  .ccluster__pat { position: absolute; border-radius: 20px; box-shadow: var(--shadow-card); }
  .ccluster__pat--back { inset: 0 0 16% 16%; transform: rotate(5deg); z-index: 0;
    background: linear-gradient(rgba(163,187,195,0.55), rgba(163,187,195,0.55)), url('/brand/patterns/pattern-2.jpg') center / 200px repeat, var(--blue); }
  .ccluster__pat--front { inset: 11% 14% 4% 2%; transform: rotate(-3deg); z-index: 1;
    background: linear-gradient(rgba(255,190,159,0.42), rgba(255,190,159,0.42)), url('/brand/patterns/pattern-5.jpg') center / 200px repeat, var(--peach); }
  .ccluster__photo {
    position: absolute; inset: 6% 9% 9% 6%; object-fit: cover; border-radius: 16px; z-index: 2;
    -webkit-mask-image: radial-gradient(130% 130% at 50% 45%, #000 76%, transparent 100%);
    mask-image: radial-gradient(130% 130% at 50% 45%, #000 76%, transparent 100%);
  }
  /* brand pattern washed over the empty top of the photo, fading into it */
  .ccluster__wash {
    position: absolute; inset: 6% 9% 9% 6%; z-index: 2; border-radius: 16px; pointer-events: none;
    background: linear-gradient(rgba(255,190,159,0.5), rgba(255,190,159,0.5)), url('/brand/patterns/pattern-5.jpg') center / 170px repeat;
    -webkit-mask-image: linear-gradient(to bottom, #000 0, rgba(0,0,0,0.55) 22%, transparent 52%);
    mask-image: linear-gradient(to bottom, #000 0, rgba(0,0,0,0.55) 22%, transparent 52%);
  }
  .cstk { position: absolute; z-index: 3; height: auto; filter: drop-shadow(0 6px 12px rgba(58,42,30,0.25)); }
  .cstk--1 { top: -10%; left: -6%; width: 104px; transform: rotate(-10deg); }
  .cstk--2 { bottom: -10%; right: -5%; width: 112px; transform: rotate(8deg); }
  .cstk--3 { top: -8%; right: -7%; width: 80px; transform: rotate(-5deg); }

  .cmethods { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
  .cmethod {
    display: flex; align-items: center; gap: var(--space-2); text-decoration: none; color: inherit;
    background: var(--cream); border: 2px solid transparent; border-radius: 16px; padding: var(--space-3);
    box-shadow: var(--shadow-card); transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .cmethod:hover { transform: translateY(-3px); border-color: var(--rust); }
  .cmethod__icon { flex: none; display: grid; place-items: center; width: 3rem; height: 3rem; border-radius: 50%; background: var(--rust); color: var(--cream); }
  .cmethod__icon svg { width: 1.5rem; height: 1.5rem; }
  .cmethod__body { display: flex; flex-direction: column; flex: 1; }
  .cmethod__label { font-family: var(--font-heading); font-size: var(--text-lg); color: var(--brown); }
  .cmethod__value { font-size: var(--text-sm); color: var(--color-text-muted); }
  .cmethod__go { color: var(--rust); font-weight: 700; flex: none; }

  @media (max-width: 760px) {
    .split { grid-template-columns: 1fr; }
    .ccluster { order: -1; width: min(320px, 82%); }
    .cmethods { grid-template-columns: 1fr; }
  }
</style>
