---
import EngagementLayout from '../../layouts/EngagementLayout.astro';
import MonthTimeline from '../../components/MonthTimeline.astro';
import EmptySeat from '../../components/EmptySeat.astro';

const weeks = [
  { label: 'Listen', title: 'Audience intelligence', desc: 'Ongoing mining of what your market actually says and asks — the input most strategies never get.' },
  { label: 'Build', title: 'Strategy + activation', desc: 'AEO/GEO and SEO in one strategy, turned into content engineered to be cited.' },
  { label: 'Watch', title: 'Monitoring + reporting', desc: 'Tracking what AI says and whether citations are turning into real traffic and demand.' },
  { label: 'Repeat', title: 'Feed it back', desc: 'Each month’s learnings sharpen the next. For agencies, all of it runs behind your brand — you’re the face, I’m the lane.' },
];
---
<EngagementLayout
  title="Embedded Partner"
  eyebrow="ongoing · agencies + in-house"
  lede="The AI visibility expertise your team isn’t staffed for — embedded with you on a monthly cadence, for agencies and in-house teams alike."
  heroImage="/images/laura-writing.jpg"
  description="An ongoing monthly AI visibility partner for agencies and in-house teams: audience intelligence, strategy, content activation and monitoring — can run fully behind your brand."
>
  <section class="band">
    <div class="container split">
      <div data-reveal="left">
        <p class="subhead">who this is for</p>
        <h2>Teams who want the lane covered, properly</h2>
        <p>
          Most agency teams aren’t staffed for AI visibility, and most in-house teams
          are stretched too thin to go deep on it. I embed as your strategy partner,
          bringing the audience intelligence and AI visibility work that compounds
          across a portfolio. For agencies it’s often fully white-labeled: I’m the
          expertise, you’re the face to the client.
        </p>
      </div>
      <EmptySeat />
    </div>
  </section>

  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">what every month looks like</p>
        <h2>The loop, on a monthly cadence</h2>
        <p>The first two to three months are about setting the foundation — I run the audit, outline the strategy, and get the key pieces in place. From there, we enter the loop: the ongoing work that keeps it compounding.</p>
      </div>
      <div data-reveal>
        <MonthTimeline weeks={weeks} />
      </div>
      <div class="boom boom--dark" data-reveal style="margin-top: var(--space-5)">
        <span class="boom__badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6"/><path d="M10 21h4"/><path d="M12 3a6 6 0 0 0-4 10.5c.7.8 1 1.6 1 2.5h6c0-.9.3-1.7 1-2.5A6 6 0 0 0 12 3z"/></svg>
          the secret sauce
        </span>
        <p class="boom__big">With LSX Partners, you always have a direct line to the latest in AI visibility.</p>
        <p class="boom__sub">
          I track everything moving in this space — new platforms, shifting citation
          weights, fresh best practices — so your strategy reflects what’s true this
          month, not last quarter. This is the part you can’t google or ask AI about.
        </p>
      </div>
    </div>
  </section>

  <section class="band tex-cream">
    <div class="container">
      <div data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">two ways this runs</p>
        <h2>Structured to fit how you work</h2>
      </div>
      <div class="cards">
        <div class="card" data-reveal>
          <h3>For agencies</h3>
          <p>A monthly retainer, per client — fully white-labeled. I’m the AI-visibility lane behind your team; your client only ever sees your brand.</p>
        </div>
        <div class="card" data-reveal data-reveal-delay="1">
          <h3>For brands</h3>
          <p>A dedicated, deeper engagement scoped to one brand — yours. More hands-on and more embedded, priced for that focus.</p>
        </div>
      </div>
      <div class="boom" data-reveal style="margin-top: var(--space-5)">
        <span class="boom__badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
          bonus scope
        </span>
        <p class="boom__big">AI visibility is the lead, not the limit.</p>
        <p class="boom__sub">
          A big part of the work is translating what we learn into the rest of your
          marketing — social, experiential, the openings most teams walk right past.
        </p>
      </div>
    </div>
  </section>
</EngagementLayout>

<style>
  .boom { max-width: 52rem; margin-inline: auto; text-align: center; }
  .boom__badge { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--font-sub); font-style: italic; font-weight: 800; font-size: var(--text-sm); padding: 0.4rem 0.9rem; border-radius: 999px; margin-bottom: var(--space-2); }
  .boom__badge svg { width: 1.1rem; height: 1.1rem; }
  .boom .boom__badge { background: var(--rust); color: var(--cream); }
  .boom--dark .boom__badge { background: var(--peach); color: var(--brown); }
  .boom__big { font-family: var(--font-heading); font-size: clamp(2rem, 1.3rem + 3vw, 3.4rem); line-height: 1.12; margin: 0 0 var(--space-2); color: var(--rust); }
  .boom--dark .boom__big { color: var(--peach); }
  .boom__sub { font-size: var(--text-lg); margin: 0 auto; max-width: 58ch; }
</style>
