---
import EngagementLayout from '../../layouts/EngagementLayout.astro';
import AnswerBlock from '../../components/AnswerBlock.astro';
import ScoreTicker from '../../components/ScoreTicker.astro';
import PinMap from '../../components/PinMap.astro';
import QueryContrast from '../../components/QueryContrast.astro';

const lenses = [
  { t: 'Prompt audit', d: 'The real situations your buyers describe, run across ChatGPT, Claude, Gemini, Perplexity and Google AI — with every source each one cites captured.' },
  { t: 'Extractability check', d: 'Whether your own pages are even structured for AI to read and quote you in the first place.' },
  { t: 'Off-site map', d: 'Where your brand exists beyond your website — reviews, Reddit, comparisons — because that’s where AI builds your identity.' },
  { t: 'Findings + gaps', d: 'A clear read on where you show up, where you don’t, and the difference between owning the answer and owning the citation.' },
];
---
<EngagementLayout
  title="AI Visibility Audit"
  eyebrow="diagnostic"
  lede="The honest baseline: what AI actually says about a brand, with receipts. It’s how agencies scope a client engagement before quoting, and how any team gets a clear read before the bigger work."
  heroImage="/images/audit-hero.jpg"
  heroRatio="4 / 3"
  description="A manual prompt audit across every major AI platform plus audience intelligence: where a brand shows up in AI answers, where it doesn’t, and why — the gap-check agencies use to scope, and the baseline before a Blueprint or Intensive."
>
  <section class="band">
    <div class="container start-split">
      <div data-reveal="left">
        <ScoreTicker />
      </div>
      <div data-reveal="right">
        <p class="subhead">the starting point</p>
        <h2>How do you find out what AI says about your brand?</h2>
        <AnswerBlock>
          You run the real situations your buyers describe through every major AI engine —
          ChatGPT, Claude, Gemini, Perplexity, Google AI — and record what each one says
          about you and which sources it cites. That’s an AI visibility audit.
        </AnswerBlock>
        <p>
          A single “score” isn’t that baseline. <strong>Agencies</strong> use the audit to
          find the gaps in a client’s strategy and scope the work accurately.
          <strong>Brands</strong> serious about fixing it usually fold the audit into the
          month-long Intensive, where it comes with the plan.
        </p>
      </div>
    </div>
  </section>

  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">what i look at</p>
        <h2>Four lenses, one set of findings</h2>
      </div>
      <div data-reveal>
        <PinMap items={lenses} />
      </div>
    </div>
  </section>

  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">why keyword tools miss it</p>
        <h2>Your buyers stopped typing keywords</h2>
      </div>
      <div data-reveal>
        <QueryContrast />
      </div>
    </div>
  </section>
</EngagementLayout>

<style>
  .start-split { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: var(--space-4); align-items: center; }
  @media (max-width: 760px) { .start-split { grid-template-columns: 1fr; } }
</style>
