---
import EngagementLayout from '../../layouts/EngagementLayout.astro';
import MonthTimeline from '../../components/MonthTimeline.astro';
import { CTA } from '../../consts';

// FLAGSHIP — the $70–100k one-month intensive (big-brand hero offer).
// Name is a PLACEHOLDER pending the CMO audience-intel naming work.
// No pricing — premium, by scope.
const deliverables = [
  { n: '01', t: 'The full picture', d: 'Where your brand stands across ChatGPT, Claude, Gemini, Perplexity and Google AI — what gets said, what gets cited, and who’s getting the credit instead of you.' },
  { n: '02', t: 'Audience intelligence', d: 'The real language your buyers use, mined from where they actually talk — the input most brand strategies are missing entirely.' },
  { n: '03', t: 'Your AI brand identity', d: 'What the internet has decided you are, where that diverges from how you see yourself, and the third-party sources you can uniquely amplify in your favor.' },
  { n: '04', t: 'The mapped strategy', d: 'A prioritized, brand-specific roadmap: where your real opportunities are, what to do about them, and in what order. The judgment, not a checklist.' },
  { n: '05', t: 'Department alignment', d: 'Every team that touches this — marketing, brand, legal and compliance, web — walked through the plan and bought into their part of it. This is the hard part, and it’s the whole point.' },
  { n: '06', t: 'A path your team can follow', d: 'You leave the month with an agreed direction and the monitoring in place to track it — so the work actually moves once I’m gone.' },
];
const weeks = [
  { label: 'See', title: 'Audit + immersion', desc: 'I run the full AI audit and go deep — interviewing the teams that touch this, learning each area’s audiences and the third-party sites that actually matter to them.' },
  { label: 'Map', title: 'Build the strategy', desc: 'Audience intelligence + everything I’ve gathered, synthesized into a prioritized strategy built around your brand, your real audiences, and where AI actually sources.' },
  { label: 'Align', title: 'Get everyone on board', desc: 'Walk every relevant department through the plan and their role, so nothing stalls in review later.' },
  { label: 'Hand off', title: 'Leave the path', desc: 'Exec-ready strategy, the agreed path, and monitoring live — your team can run with it.' },
];
---
<EngagementLayout
  title="The AI Visibility Intensive"
  eyebrow="the flagship · one month"
  lede="When a big brand needs to get serious about AI visibility, I come in for one month: audit where you stand, map the strategy, and get every relevant department aligned on the path — so the plan actually moves once I’m gone."
  heroImage="/images/intensive-power.jpg"
  heroRatio="3 / 4"
  description="A one-month flagship engagement: I audit your AI visibility, map the strategy to your brand, and align every relevant department on a clear path to follow."
>
  <!-- WHO IT'S FOR -->
  <section class="band">
    <div class="container measure" data-reveal>
      <p class="subhead">who this is for</p>
      <h2>The brand that can’t wait another quarter to own its AI brand identity</h2>
      <p>
        You’re a known name. You rank fine on Google — for now. But clicks from
        the usual sources are about to drop fast as buyers ask ChatGPT, Perplexity
        and Gemini instead, and right now those answers are missing you, getting
        you wrong, or handing the credit to a competitor and a Reddit thread. You
        don’t want to be playing catch-up when that shift fully lands — you want to
        already own your AI brand identity and everything that comes with it. So we
        skip the slow retainer: I come in, find the truth, map the strategy, and
        get your whole organization pointed the same direction in a month.
      </p>
    </div>
  </section>

  <!-- WHAT YOU GET (forest) -->
  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal>
        <p class="subhead">what you walk away with</p>
        <h2>One month. The strategy and the buy-in.</h2>
      </div>
      <div class="delivs">
        {deliverables.map((d, i) => (
          <div class="deliv" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <span class="deliv__check" aria-hidden="true">✓</span>
            <div>
              <h3>{d.t}</h3>
              <p>{d.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW THE MONTH WORKS (cream texture) -->
  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">how the month works</p>
        <h2>Four weeks, four moves<span class="asterisk">*</span></h2>
      </div>
      <div data-reveal>
        <MonthTimeline weeks={weeks} />
      </div>
      <p class="disclaimer" data-reveal>*Scoped as one month. A project can run up to 5–6 weeks depending on stakeholder availability and scheduling.</p>
    </div>
  </section>

  <!-- WHY IT WORKS (rust) -->
  <section class="band section--rust">
    <div class="container">
      <div class="measure" data-reveal="left">
        <p class="subhead">why it works</p>
        <h2>I’m in this every single day</h2>
        <p>
          I test the tools myself and run this process across real client work, so
          you get learnings months before the standard agency cycle would surface them.
          That’s why the strategy I map actually gets agreed on and moves, instead of
          stalling the second it hits someone’s queue.
        </p>
      </div>
      <div class="creds">
        <div class="cred" data-reveal><span class="cred__big">15+ yrs</span><span>across agency &amp; corporate marketing</span></div>
        <div class="cred" data-reveal data-reveal-delay="1"><span class="cred__big">Regulated</span><span>healthcare &amp; MedTech — medical, legal &amp; brand sign-off</span></div>
        <div class="cred" data-reveal data-reveal-delay="2"><span class="cred__big">Every day</span><span>testing tools + running real client work</span></div>
      </div>
      <a class="button" href={CTA.calendly} style="margin-top: var(--space-4)">See if it’s a fit</a>
    </div>
  </section>
</EngagementLayout>

<style>
  .delivs { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3) var(--space-4); margin-top: var(--space-4); }
  .deliv { display: flex; gap: var(--space-2); align-items: flex-start; }
  .deliv__check { flex: none; width: 1.9rem; height: 1.9rem; border-radius: 50%; display: grid; place-items: center; background: var(--peach); color: var(--brown); font-weight: 700; }
  .deliv h3 { color: var(--peach); margin: 0 0 0.2rem; font-size: var(--text-lg); }
  .deliv p { margin: 0; font-size: var(--text-sm); color: var(--cream); opacity: 0.92; }
  @media (max-width: 680px) { .delivs { grid-template-columns: 1fr; } }

  /* Credentials strip on the rust band */
  .creds { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); margin-top: var(--space-4); }
  .cred { display: flex; flex-direction: column; gap: 0.2rem; border-top: 2px solid rgba(252, 245, 229, 0.4); padding-top: var(--space-2); }
  .cred__big { font-family: var(--font-heading); font-size: var(--text-2xl); color: var(--cream); line-height: 1; }
  .cred span:last-child { font-size: var(--text-sm); color: var(--cream); opacity: 0.9; }
  @media (max-width: 680px) { .creds { grid-template-columns: 1fr; } }

  .asterisk { color: var(--rust); }
  .disclaimer { margin-top: var(--space-3); font-size: var(--text-sm); font-style: italic; color: var(--color-text-muted); max-width: 60ch; }
</style>
