---
import EngagementLayout from '../../layouts/EngagementLayout.astro';
import { CTA } from '../../consts';

// FLAGSHIP — the $70–100k one-month intensive (big-brand hero offer).
// Name is a PLACEHOLDER pending the CMO audience-intel naming work.
// No pricing — premium, by scope.
const deliverables = [
  { n: '01', t: 'The full picture', d: 'Where your brand stands across ChatGPT, Claude, Perplexity and Google AI — what gets said, what gets cited, and who’s getting the credit instead of you.' },
  { n: '02', t: 'Audience intelligence', d: 'The real language your buyers use, mined from where they actually talk — the input most brand strategies are missing entirely.' },
  { n: '03', t: 'Your AI brand identity', d: 'What the internet has decided you are, where that diverges from how you see yourself, and the third-party sources you can uniquely amplify in your favor.' },
  { n: '04', t: 'The mapped strategy', d: 'A prioritized, brand-specific roadmap: where your real opportunities are, what to do about them, and in what order. The judgment, not a checklist.' },
  { n: '05', t: 'Department alignment', d: 'Every team that touches this — marketing, brand, legal and compliance, web — walked through the plan and bought into their part of it. This is the hard part, and it’s the whole point.' },
  { n: '06', t: 'A path your team can follow', d: 'You leave the month with an agreed direction and the monitoring in place to track it — so the work actually moves once I’m gone.' },
];
const weeks = [
  { t: 'Week 1 — See', d: 'Audit and audience intelligence. We establish the truth: what AI says, what buyers ask, where you’re absent.' },
  { t: 'Week 2 — Map', d: 'Turn the findings into a prioritized strategy built around your brand and the openings specific to you.' },
  { t: 'Week 3 — Align', d: 'Walk every relevant department through the plan and their role, so nothing stalls in review later.' },
  { t: 'Week 4 — Hand off', d: 'Exec-ready strategy, the agreed path, and monitoring live — your team can run with it.' },
];
---
<EngagementLayout
  title="The AI Visibility Intensive"
  eyebrow="the flagship · one month"
  lede="When a big brand needs to get serious about AI visibility, I come in for one month: audit where you stand, map the strategy, and get every relevant department aligned on the path — so the plan actually moves once I’m gone."
  heroImage="/images/laura-blazer-phone.jpg"
  description="A one-month flagship engagement: I audit your AI visibility, map the strategy to your brand, and align every relevant department on a clear path to follow."
>
  <!-- WHO IT'S FOR -->
  <section class="band">
    <div class="container measure" data-reveal>
      <p class="subhead">who this is for</p>
      <h2>The brand that can’t wait a year to find out what AI is saying about them</h2>
      <p>
        You’re a known name. You rank fine on Google. But when someone asks
        ChatGPT or Perplexity about your category, you’re either missing, wrong,
        or getting credit handed to a competitor and a Reddit thread. You don’t
        need another dashboard or a slow retainer to ease into it. You need
        someone who’s done this every day to come in, find the truth, map the
        strategy, and get your whole organization pointed the same direction.
      </p>
    </div>
  </section>

  <!-- WHAT YOU GET (forest) -->
  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal>
        <p class="subhead">what you walk away with</p>
        <h2>One month. The strategy and the buy-in.</h2>
      </div>
      <div class="cards">
        {deliverables.map((d, i) => (
          <div class="card" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <span class="card__n">{d.n}</span>
            <h3>{d.t}</h3>
            <p>{d.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW THE MONTH WORKS (cream texture) -->
  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal>
        <p class="subhead">how the month works</p>
        <h2>Four weeks, four moves</h2>
      </div>
      <div class="steps">
        {weeks.map((w, i) => (
          <div class="step" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <span class="step__n">{i + 1}</span>
            <h3>{w.t}</h3>
            <p>{w.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY IT WORKS (rust) -->
  <section class="band section--rust">
    <div class="container measure" data-reveal="left">
      <p class="subhead">why it works</p>
      <h2>I’m in this every single day</h2>
      <p>
        I test the tools myself and run this process across real client work, so
        you get learnings months before the standard agency cycle would surface
        them. I’ve spent 15+ years across agency and corporate, including regulated
        industries where nothing ships without medical, legal and brand sign-off.
        That’s why the strategy I map actually gets agreed on and moves, instead of
        stalling the second it hits someone’s queue.
      </p>
      <a class="button" href={CTA.calendly}>See if it’s a fit</a>
    </div>
  </section>
</EngagementLayout>
