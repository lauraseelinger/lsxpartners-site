---
import EngagementLayout from '../../layouts/EngagementLayout.astro';
import LayerStack from '../../components/LayerStack.astro';

const deliverables = [
  { n: '01', t: 'The architecture call', d: 'Which pages exist, how they’re organized, and what each one has to answer — mapped to how your buyers actually search, so the site is built around the right questions from day one.' },
  { n: '02', t: 'Page-type strategy', d: 'What a product page, a category page, and a hub each need to do differently to earn a citation in your category. The judgment, drawn from your brand, not a one-size template.' },
  { n: '03', t: 'A build-ready spec', d: 'Templates and the structural markup handed to your developers, fully specified. The mechanical part is easy — I make sure no one has to guess at it.' },
  { n: '04', t: 'Where your openings are', d: 'A prioritized read on the opportunities specific to your brand — what to amplify and what to build next — to seed the work after launch.' },
];
---
<EngagementLayout
  title="AI Visibility Blueprint"
  eyebrow="project"
  lede="Building or rebuilding your site? Do it structurally optimized for AI from the ground up — instead of bolting on fixes across a finished site later."
  heroImage="/images/laura-3.jpg"
  heroRatio="4 / 5"
  description="The strategy layer for a website redesign or new build: architecture and page-type decisions mapped to your brand, a build-ready spec, and a prioritized list of where your AI visibility opportunities are."
>
  <section class="band">
    <div class="container measure" data-reveal>
      <p class="subhead">who this is for</p>
      <h2>Brands (and the agencies rebuilding their sites)</h2>
      <p>
        A redesign is the cheapest time to get AI visibility right, because you’re
        building the structure anyway. The Blueprint is the strategy layer that
        rides alongside the rebuild — the decisions about what the site should say
        and how it should be organized for your brand — so it’s built right from
        day one instead of needing quarters of patches after launch. I work directly
        with brands and as the embedded strategy lane inside agency redesign teams.
      </p>
    </div>
  </section>

  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal><p class="subhead">what’s in it · built up layer by layer</p><h2>The website foundation</h2></div>
      <div data-reveal>
        <LayerStack layers={deliverables} />
      </div>
    </div>
  </section>

  <section class="band tex-cream">
    <div class="container measure" data-reveal="left">
      <p class="subhead">the payoff</p>
      <h2>Build the railway while everyone else patches tires on the side of the road</h2>
      <p>
        The brands that get the structure right now will implement at a speed their
        competitors can’t once AI optimization is as documented as SEO is today.
        A Blueprint during a redesign means you’re optimized from the ground up —
        not making little updates across a site that was never built for it.
      </p>
    </div>
  </section>
</EngagementLayout>
