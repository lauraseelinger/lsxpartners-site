---
import BaseLayout from '../layouts/BaseLayout.astro';
import FramedPhoto from '../components/FramedPhoto.astro';
import StitchDivider from '../components/StitchDivider.astro';
import { faqSchema } from '../lib/schema';
import { PERSON, CTA } from '../consts';

// ABOUT — the entity anchor. Person schema is emitted site-wide (BaseLayout);
// this page is its canonical home (rel=author points here). Image-forward,
// color-blocked, with movement: split pattern/photo hero, floating monitored
// signals, a scrolling toolkit, counting creds. Full LinkedIn Laura voice.
// Backstory facts are real (Libbey, regulated healthcare, 15+ yrs, MBA, Cincy).
const monitors = ['ChatGPT', 'Perplexity', 'Claude', 'Gemini', 'Google AI Overviews', 'Reddit threads', 'your reviews', 'buyer questions'];
const stack = ['ChatGPT', 'Claude', 'Gemini', 'Perplexity', 'Google AI Overviews', 'Copilot', 'Grok', 'Semrush', 'Ahrefs', 'Reddit', '…and three I’m testing this week'];
const offclock = ['writing Cited 📨', 'Cincy AI Week 🎤', 'my cats 🐈', 'wood-stove fires 🔥', 'Friday audits, for fun'];
const faqs = [
  {
    question: 'Who is Laura Seelinger?',
    answer:
      'Laura Seelinger is an AI visibility expert and the founder of LSX Partners. She helps brands and agencies get cited by AI engines like ChatGPT, Claude, Gemini, and Perplexity, drawing on 15+ years in agency and corporate marketing — much of it in regulated industries like healthcare and MedTech.',
  },
  {
    question: 'What does LSX Partners do?',
    answer:
      'LSX Partners is an AI visibility and strategy practice. It audits what AI engines actually say about a brand, then builds the strategy and content so those engines quote the brand as a source — not just rank it.',
  },
  {
    question: 'Who does Laura work with?',
    answer:
      'Both in-house brand teams and agencies — agency work is often white-labeled. Engagements range from a one-time AI visibility audit to a focused one-month intensive to an ongoing monthly partnership.',
  },
];
---
<BaseLayout
  title={`About ${PERSON.name}`}
  description="Laura Seelinger is an AI visibility expert and founder of LSX Partners, helping brands and agencies get cited by AI — 15+ years in agency and corporate marketing, much of it in regulated industries."
  schemas={[faqSchema(faqs)]}
>
  <!-- HERO — half pattern, half playful photo -->
  <section class="ahero">
    <div class="ahero__text">
      <p class="subhead">ai visibility expert · founder, lsx partners</p>
      <h1>Hi, I'm Laura.</h1>
      <p class="ahero__lede">
        I'm the AI marketing nerd who actually looks forward to the monthly
        reporting. I help brands and agencies get <strong>cited by AI</strong> —
        and I'm in this every single day.
      </p>
      <a class="button" href={CTA.calendly}>Let's talk AI visibility</a>
    </div>
    <div class="ahero__photo">
      <img src="/images/laura-couch.jpg" alt="Laura Seelinger working from the couch" />
    </div>
  </section>

  <!-- THE GAP — signals I monitor float around me -->
  <StitchDivider bg="cream" stitch="rust" />
  <section class="band section--cream">
    <div class="container gap-grid">
      <div class="orbit" data-reveal aria-hidden="false">
        <img class="orbit__me" src="/images/laura-kitchen.jpg" alt="Laura Seelinger" />
        {monitors.map((m, i) => (
          <span class={`float float--${i % 4}`} style={`--i:${i}`}>{m}</span>
        ))}
      </div>
      <div data-reveal="right">
        <p class="subhead">the gap i live in</p>
        <h2>What AI says about you is the new front page</h2>
        <p>
          When someone asks ChatGPT, Claude, Gemini, or Perplexity about your
          category, the brand it names — and the source it credits — is what they
          act on. Most companies have no idea what AI is saying about them. That's
          the gap I live in: I watch all of it, find where you're missing, and
          close it.
        </p>
      </div>
    </div>
  </section>

  <!-- BACKGROUND — counting creds -->
  <StitchDivider bg="forest" stitch="yellow" />
  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">where i come from</p>
        <h2>I've lived both sides of the work</h2>
      </div>
      <div class="measure" data-reveal>
        <p>
          I've spent 15+ years across agency and corporate marketing. Four of them
          were at Libbey, the glassware company in Toledo — I genuinely loved the
          products and the people (I even wrote some of the Amazon copy I now roast
          in my case studies). Most of my family works in healthcare, my husband
          included, so I spent years deep in regulated marketing, where the simplest
          copy change needs sign-off from medical, legal, compliance, and brand.
        </p>
        <p>
          That background is exactly why I'm useful now. The content side is the
          easy part — getting it through a real organization is where the work
          actually happens, and I've lived both sides.
        </p>
      </div>
      <div class="creds">
        <div class="cred" data-reveal><span class="cred__big"><span data-count="15" data-suffix="+">15+</span></span><span>years across agency &amp; corporate marketing</span></div>
        <div class="cred" data-reveal data-reveal-delay="1"><span class="cred__big">Regulated</span><span>healthcare &amp; MedTech — medical, legal &amp; brand sign-off</span></div>
        <div class="cred" data-reveal data-reveal-delay="2"><span class="cred__big">MBA</span><span>plus a marketer's instinct for what actually moves</span></div>
      </div>
    </div>
  </section>

  <!-- HOW I WORK — the stack keeps moving -->
  <StitchDivider bg="cream" stitch="rust" />
  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">how i actually work</p>
        <h2>I test it on myself first</h2>
        <p>
          I don't half-a** things. I test the tools myself — I've swapped my toolkit
          more than once in six months because this space moves that fast — and I
          run my process on real products and real client work before I ever
          recommend it. My clients get the learnings months before they'd hit the
          standard agency cycle, because I'm in this every single day.
        </p>
      </div>
      <p class="stack-cap" data-reveal>the stack, give or take — it changes constantly →</p>
      <div class="marquee" data-reveal aria-hidden="true">
        <div class="marquee__track">
          {[...stack, ...stack].map((s) => <span class="tool">{s}</span>)}
        </div>
      </div>
      <div class="marquee marquee--rev" aria-hidden="true">
        <div class="marquee__track">
          {[...stack.slice().reverse(), ...stack.slice().reverse()].map((s) => <span class="tool tool--ghost">{s}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- OFF THE CLOCK — playful floating life -->
  <StitchDivider bg="olive" stitch="ivory" />
  <section class="band section--olive">
    <div class="container gap-grid gap-grid--rev">
      <div data-reveal="left">
        <p class="subhead">off the clock</p>
        <h2>Running audits on a Friday, for fun</h2>
        <p>
          When I'm not running audits on a Friday afternoon for fun, I'm probably
          writing my newsletter (<a href={CTA.newsletter}>Cited</a>), speaking at
          events like Cincy AI Week, hanging out with my cats, or asking Claude how
          to start a fire in a wood stove. I'm 100% myself here — em dashes and all.
        </p>
      </div>
      <div class="orbit orbit--life" data-reveal>
        <img class="orbit__me" src="/images/laura-phone.jpg" alt="Laura at her desk" />
        {offclock.map((m, i) => (
          <span class={`float float--${i % 4}`} style={`--i:${i}`}>{m}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <StitchDivider bg="cream" stitch="green" />
  <section class="band tex-cream">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">questions i get</p>
        <h2>A few things people ask</h2>
      </div>
      <dl class="faq">
        {faqs.map((f, i) => (
          <div class="faq__item" data-reveal data-reveal-delay={i}>
            <dt>{f.question}</dt>
            <dd>{f.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <StitchDivider bg="rust" stitch="yellow" />
  <section class="band section--rust">
    <div class="container measure measure--center" data-reveal="scale">
      <h2>Want to know what AI says about you?</h2>
      <p>That's the best first conversation we can have. Let's find out together.</p>
      <p class="about-ctas">
        <a class="button" href={CTA.calendly}>Let's talk AI visibility</a>
        <a class="button button--ghost" href={PERSON.sameAs[0]}>Find me on LinkedIn</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Split hero: pattern panel + playful photo ---- */
  .ahero { display: grid; grid-template-columns: 1.02fr 0.98fr; min-height: 78vh; }
  .ahero__text {
    display: flex; flex-direction: column; justify-content: center;
    padding: var(--space-6) var(--space-5);
    background:
      linear-gradient(rgba(252, 245, 229, 0.7), rgba(252, 245, 229, 0.7)),
      url('/brand/patterns/pattern-2.jpg') center / 300px repeat,
      var(--cream);
  }
  .ahero__text h1 { font-size: clamp(2.8rem, 1.9rem + 4vw, 5rem); margin-block: var(--space-1) var(--space-2); }
  .ahero__lede { font-size: var(--text-lg); max-width: 42ch; margin-bottom: var(--space-3); }
  .ahero__photo { position: relative; overflow: hidden; }
  .ahero__photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 28%; }
  /* feather the seam so the photo melts into the pattern */
  .ahero__photo::before {
    content: ''; position: absolute; inset: 0 auto 0 0; width: 28%;
    background: linear-gradient(90deg, var(--cream), transparent); z-index: 2;
  }

  .band { padding-block: var(--space-6); }
  .measure { max-width: 44rem; }
  .measure--center { margin-inline: auto; text-align: center; }

  /* ---- Two-up grid (photo/orbit + text) ---- */
  .gap-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: var(--space-5); align-items: center; }
  .gap-grid > div:last-child { max-width: 52ch; }

  /* ---- Orbit: photo with floating signals drifting around it ---- */
  .orbit { position: relative; width: min(360px, 92%); aspect-ratio: 1; margin-inline: auto; }
  .orbit__me {
    position: absolute; inset: 12%; width: 76%; height: 76%; object-fit: cover; border-radius: 50%;
    -webkit-mask-image: radial-gradient(closest-side, #000 78%, transparent 100%);
    mask-image: radial-gradient(closest-side, #000 78%, transparent 100%);
    box-shadow: var(--shadow-card);
  }
  .float {
    position: absolute; white-space: nowrap; z-index: 3;
    font-family: var(--font-sub); font-weight: 800; font-style: italic; font-size: var(--text-sm);
    background: var(--cream); color: var(--rust); padding: 0.32rem 0.7rem; border-radius: 999px;
    box-shadow: var(--shadow-card); animation: floatA 6s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * -0.8s);
  }
  /* scatter the chips around the ring */
  .orbit .float:nth-child(2) { top: 2%; left: 8%; }
  .orbit .float:nth-child(3) { top: 0%; right: 4%; }
  .orbit .float:nth-child(4) { top: 38%; left: -6%; }
  .orbit .float:nth-child(5) { top: 30%; right: -8%; }
  .orbit .float:nth-child(6) { bottom: 20%; left: -4%; }
  .orbit .float:nth-child(7) { bottom: 4%; right: 2%; }
  .orbit .float:nth-child(8) { bottom: -2%; left: 26%; }
  .orbit .float:nth-child(9) { top: 50%; right: 18%; }
  .float--1 { animation-name: floatB; }
  .float--2 { animation-name: floatC; }
  .float--3 { animation-name: floatA; animation-duration: 7.5s; }
  /* off-the-clock chips read olive/cream */
  .orbit--life .float { color: var(--olive); }

  @keyframes floatA { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-12px) } }
  @keyframes floatB { 0%,100% { transform: translate(0,0) } 50% { transform: translate(7px, 9px) } }
  @keyframes floatC { 0%,100% { transform: translate(0,0) rotate(-3deg) } 50% { transform: translate(-8px,-7px) rotate(3deg) } }

  /* ---- Credential strip (forest) ---- */
  .creds { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); margin-top: var(--space-4); }
  .cred { display: flex; flex-direction: column; gap: 0.3rem; }
  .cred__big { font-family: var(--font-heading); font-size: var(--text-2xl); color: var(--cream); line-height: 1; }

  /* ---- Moving toolkit marquee ---- */
  .stack-cap { font-family: var(--font-sub); font-weight: 800; font-style: italic; color: var(--olive); margin: var(--space-4) 0 var(--space-2); }
  .marquee { overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
  .marquee + .marquee { margin-top: var(--space-1); }
  .marquee__track { display: flex; gap: var(--space-2); width: max-content; animation: scroll-x 26s linear infinite; }
  .marquee--rev .marquee__track { animation-direction: reverse; animation-duration: 32s; }
  .marquee:hover .marquee__track { animation-play-state: paused; }
  .tool {
    flex: none; font-family: var(--font-sub); font-weight: 800; font-style: italic; font-size: var(--text-lg);
    color: var(--brown); background: var(--cream); border: 1.5px solid var(--color-border);
    padding: 0.5rem 1rem; border-radius: 12px; box-shadow: var(--shadow-card);
  }
  .tool--ghost { color: var(--color-text-muted); background: transparent; box-shadow: none; opacity: 0.8; }
  @keyframes scroll-x { from { transform: translateX(0) } to { transform: translateX(-50%) } }

  /* ---- FAQ ---- */
  .faq { display: grid; gap: var(--space-3); margin: 0; }
  .faq__item { border-left: 3px solid var(--rust); padding-left: var(--space-2); }
  .faq dt { font-family: var(--font-heading); font-size: var(--text-lg); color: var(--brown); margin-bottom: 0.3rem; }
  .faq dd { margin: 0; max-width: 62ch; }

  .about-ctas { display: flex; flex-wrap: wrap; gap: var(--space-1); justify-content: center; }

  @media (prefers-reduced-motion: reduce) {
    .float, .marquee__track { animation: none; }
  }
  @media (max-width: 860px) {
    .ahero { grid-template-columns: 1fr; min-height: 0; }
    .ahero__photo { min-height: 46vh; order: -1; }
    .ahero__photo::before { inset: auto 0 0 0; width: auto; height: 22%; background: linear-gradient(0deg, var(--cream), transparent); }
  }
  @media (max-width: 760px) {
    .gap-grid { grid-template-columns: 1fr; }
    .gap-grid--rev .orbit { order: -1; }
    .creds { grid-template-columns: 1fr; }
  }
</style>
