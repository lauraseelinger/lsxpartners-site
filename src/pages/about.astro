---
import BaseLayout from '../layouts/BaseLayout.astro';
import StitchDivider from '../components/StitchDivider.astro';
import { faqSchema } from '../lib/schema';
import { PERSON, CTA } from '../consts';

// ABOUT — the entity anchor. Person schema is emitted site-wide (BaseLayout);
// this page is its canonical home. Image-forward, color-blocked, with movement.
// Full LinkedIn Laura voice. Facts are real (Libbey, regulated healthcare,
// 15+ yrs agency+corporate, MBA, Cincy).
const monitors = ['LLMs', 'audience intelligence', 'third-party data', 'AI brand identity', 'citation sources', 'entity consistency', 'answer engines'];
const sides = [
  { key: 'corp', name: 'Corporate', blurb: 'Fortune-scale brand and marketing teams — process, approvals, and getting real work done at scale.' },
  { key: 'agency', name: 'Agency', blurb: 'Fast, creative, juggling a dozen clients at once — and white-labeling the deep work behind the scenes.' },
];
const verticals = [
  { name: 'Manufacturing', d: 'Long cycles, technical buyers, and dealer/distributor layers.' },
  { name: 'Automotive', d: 'Brand-and-dealer tension, and a lot of compliance.' },
  { name: 'E-commerce', d: 'Marketplace copy, reviews, and conversion.' },
  { name: 'Pharma & MedTech', d: 'Medical, legal, and regulatory sign-off on every word.' },
  { name: 'CPG', d: 'Retail, Amazon, and brand.' },
];
const offclock = ['🐈 my cats', '🥾 hiking', '🌬️ breathwork', '📔 junk journaling', '🧘 meditation', '🎧 podcasts', '🚗 road trips'];
const stickers = [
  { src: '/brand/assets/sticker-locally-sourced.png', cls: 'stk--1', rot: -8, depth: 26 },
  { src: '/brand/assets/sticker-tailored.png', cls: 'stk--2', rot: 7, depth: 40 },
  { src: '/brand/assets/sticker-team.png', cls: 'stk--3', rot: -5, depth: 16 },
  { src: '/brand/assets/sticker-organic.png', cls: 'stk--4', rot: 9, depth: 32 },
];
const faqs = [
  {
    question: 'Who is Laura Seelinger?',
    answer:
      'Laura Seelinger is an AI visibility expert and the founder of LSX Partners. She helps brands and agencies get cited by AI engines like ChatGPT, Claude, Gemini, and Perplexity, drawing on 15+ years in agency and corporate marketing — much of it in regulated industries like healthcare and MedTech.',
  },
  {
    question: 'What does LSX Partners do?',
    answer:
      'LSX Partners is an AI visibility and strategy practice. It audits what AI engines actually say about a brand, then builds the strategy and content so those engines quote the brand as a source — not just rank it.',
  },
  {
    question: 'Who does Laura work with?',
    answer:
      'Both in-house brand teams and agencies — agency work is often white-labeled. Engagements range from a one-time AI visibility audit to a focused one-month intensive to an ongoing monthly partnership.',
  },
];
---
<BaseLayout
  title={`About ${PERSON.name}`}
  description="Laura Seelinger is an AI visibility expert and founder of LSX Partners, helping brands and agencies get cited by AI — 15+ years in agency and corporate marketing, much of it in regulated industries."
  schemas={[faqSchema(faqs)]}
>
  <!-- HERO — half pattern, half photo, blended seam -->
  <section class="ahero">
    <div class="ahero__text">
      <p class="subhead">ai visibility expert · founder, lsx partners</p>
      <h1>Hi, I'm Laura.</h1>
      <p class="ahero__lede">
        I help brands and agencies get <strong>cited by AI</strong> — and I'm the
        rare marketer who actually looks forward to the monthly reporting. I'm in
        this every single day.
      </p>
      <a class="button" href={CTA.calendly}>Book a call</a>
    </div>
    <div class="ahero__photo">
      <img src="/images/about-hero.jpg" alt="Laura Seelinger" />
    </div>
  </section>

  <!-- THE GAP — advanced signals float around me -->
  <section class="band section--cream">
    <div class="container gap-grid">
      <div class="thoughts" data-reveal aria-hidden="true">
        {monitors.map((m, i) => (
          <span class={`thought thought--${i % 6}`} style={`--i:${i}`}>{m}</span>
        ))}
      </div>
      <div data-reveal="right">
        <p class="subhead">the gap i live in</p>
        <h2>What AI says about you is the new front page</h2>
        <p>
          When someone asks ChatGPT, Claude, Gemini, or Perplexity about your
          category, the brand it names — and the source it credits — is what they
          act on. Most companies have no idea what AI is saying about them. That's
          the gap I live in: I watch all of it, find where you're missing, and
          close it.
        </p>
      </div>
    </div>
  </section>

  <!-- BACKGROUND — both sides + industries accordion -->
  <StitchDivider bg="forest" stitch="yellow" />
  <section class="band section--forest">
    <div class="container">
      <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
        <p class="subhead">where i come from</p>
        <h2>I've lived both sides of the work</h2>
        <p>
          My path ran through both sides — corporate marketing teams and agencies,
          B2B and B2C, a lot of it in heavily regulated work where a single line of
          copy needs sign-off from medical, legal, and brand. That mix is the point:
          I've watched good ideas live or die inside real companies. The idea is
          rarely the hard part — getting it through the org is. And I'd always rather
          build and test something than sit in a deck theorizing about it.
        </p>
      </div>

      <div class="sides">
        {sides.map((s, i) => (
          <div class="side" data-reveal data-reveal-delay={i + 1}>
            {s.key === 'corp' ? (
              <svg viewBox="0 0 48 48" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="11" y="6" width="26" height="38" rx="2" /><line x1="6" y1="44" x2="42" y2="44" />
                <line x1="18" y1="14" x2="20" y2="14" /><line x1="28" y1="14" x2="30" y2="14" />
                <line x1="18" y1="22" x2="20" y2="22" /><line x1="28" y1="22" x2="30" y2="22" />
                <line x1="18" y1="30" x2="20" y2="30" /><line x1="28" y1="30" x2="30" y2="30" />
              </svg>
            ) : (
              <svg viewBox="0 0 48 48" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M26 4 L12 26 L23 26 L20 44 L36 20 L25 20 Z" />
              </svg>
            )}
            <h3>{s.name}</h3>
            <p>{s.blurb}</p>
          </div>
        ))}
      </div>

      <p class="rooms-line" data-reveal>
        <span class="rooms-line__cap">across a lot of rooms —</span>
        {verticals.map((v, i) => (
          <span class="room-name">{v.name}{i < verticals.length - 1 ? <span class="dot"> · </span> : null}</span>
        ))}
      </p>
    </div>
  </section>

  <!-- HOW I WORK — the coach's playbook, small + blended into the corner -->
  <StitchDivider bg="cream" stitch="rust" />
  <section class="band tex-cream how-band">
    <div class="container how-grid">
      <div class="measure" data-reveal>
        <p class="subhead">how i actually work</p>
        <h2>I test it on myself first</h2>
        <p>
          I don't half-a** things. I test the tools myself and run the whole process
          on my own brand first — so by the time it reaches you it's proven, not an
          experiment on your dime. I'm also not precious about my methods: when the
          space shifts, I shift with it. The playbook's never finished, and every
          new test runs on my own work before yours.
        </p>
      </div>
      <figure class="playbook" data-reveal aria-hidden="true">
        <span class="playbook__tag">the play, this round</span>
        <svg viewBox="0 0 300 210" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <!-- field hashes -->
        <g stroke="var(--brown)" stroke-width="1" opacity="0.18">
          <line x1="20" y1="70" x2="280" y2="70" /><line x1="20" y1="120" x2="280" y2="120" />
        </g>
        <!-- routes -->
        <path d="M70 150 C 64 110 44 100 40 64" stroke="var(--rust)" stroke-width="3" stroke-dasharray="2 8" />
        <path d="M230 150 C 236 112 258 104 262 70" stroke="var(--olive)" stroke-width="3" stroke-dasharray="2 8" />
        <path d="M150 150 C 150 120 150 110 150 78" stroke="var(--brown)" stroke-width="3" stroke-dasharray="2 8" />
        <path d="M40 64 l-7 12 M40 64 l9 9" stroke="var(--rust)" stroke-width="3" />
        <path d="M262 70 l-9 9 M262 70 l7 12" stroke="var(--olive)" stroke-width="3" />
        <path d="M150 78 l-8 10 M150 78 l8 10" stroke="var(--brown)" stroke-width="3" />
        <!-- offense O's on the line -->
        <g stroke="var(--brown)" stroke-width="3" fill="#fbf7ee">
          <circle cx="70" cy="158" r="11" /><circle cx="110" cy="158" r="11" /><circle cx="150" cy="158" r="11" />
          <circle cx="190" cy="158" r="11" /><circle cx="230" cy="158" r="11" />
        </g>
        <!-- QB -->
        <circle cx="150" cy="190" r="10" stroke="var(--rust)" stroke-width="3" fill="none" />
        <!-- defender X -->
        <path d="M143 44 l14 14 M157 44 l-14 14" stroke="var(--brown)" stroke-width="3" opacity="0.7" />
      </svg>
      </figure>
    </div>
  </section>

  <!-- OFF THE CLOCK -->
  <StitchDivider bg="olive" stitch="ivory" />
  <section class="band section--olive">
    <div class="container gap-grid gap-grid--rev">
      <div data-reveal="left">
        <p class="subhead">off the clock</p>
        <h2>What I'm into when I log off</h2>
        <p>
          When I'm not mapping a strategy or down an AI visibility research rabbit
          hole, I'm probably hanging with my cats, going on a hike, junk journaling
          (it's my new creative outlet), or mapping out my husband and my next
          adventures. I'm 100% myself here — em dashes and all.
        </p>
      </div>
      <div class="orbit orbit--life" data-reveal>
        <img class="orbit__me" src="/images/laura-floor-phone.jpg" alt="Laura laughing" />
        {offclock.map((m, i) => (
          <span class={`float float--${i % 4}`} style={`--i:${i}`}>{m}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ — with a stack of distinct brand stickers -->
  <StitchDivider bg="cream" stitch="green" />
  <section class="band tex-cream">
    <div class="container faq-grid">
      <div>
        <div class="measure" data-reveal style="margin-bottom: var(--space-3)">
          <p class="subhead">questions i get</p>
          <h2>A few things people ask</h2>
        </div>
        <dl class="faq">
          {faqs.map((f, i) => (
            <div class="faq__item" data-reveal data-reveal-delay={i}>
              <dt>{f.question}</dt>
              <dd>{f.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div class="stickers" data-reveal aria-hidden="true">
        <div class="stickers__pattern"></div>
        {stickers.map((s) => (
          <img class={`stk ${s.cls}`} src={s.src} alt="" data-stk data-rot={s.rot} data-depth={s.depth} style={`transform: rotate(${s.rot}deg)`} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <StitchDivider bg="rust" stitch="yellow" />
  <section class="band section--rust">
    <div class="container measure measure--center" data-reveal="scale">
      <h2>Want to know what AI says about you?</h2>
      <p>Book a call and we'll talk through where you stand — the major engines, your category, your competitors.</p>
      <p class="about-ctas">
        <a class="button" href={CTA.calendly}>Book a call</a>
        <a class="button button--ghost" href={PERSON.sameAs[0]}>Find me on LinkedIn</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Half/half hero: photo masked so it dissolves into the pattern ---- */
  .ahero {
    display: grid; grid-template-columns: 1fr 1fr; min-height: clamp(360px, 46vh, 470px);
    background:
      linear-gradient(rgba(252, 245, 229, 0.72), rgba(252, 245, 229, 0.72)),
      url('/brand/patterns/pattern-2.jpg') center / 300px repeat,
      var(--cream);
  }
  .ahero__text { display: flex; flex-direction: column; justify-content: center; padding: var(--space-5); }
  .ahero__text h1 { font-size: clamp(2.4rem, 1.7rem + 3vw, 4rem); margin-block: var(--space-1) var(--space-2); }
  .ahero__lede { font-size: var(--text-lg); max-width: 40ch; margin-bottom: var(--space-3); }
  .ahero__photo { position: relative; }
  .ahero__photo img {
    width: 100%; height: 100%; object-fit: cover; object-position: 52% 30%;
    -webkit-mask-image: linear-gradient(90deg, transparent 0, rgba(0,0,0,0.4) 22%, #000 46%);
    mask-image: linear-gradient(90deg, transparent 0, rgba(0,0,0,0.4) 22%, #000 46%);
  }

  .band { padding-block: var(--space-6); }
  .measure { max-width: 44rem; }
  .measure--center { margin-inline: auto; text-align: center; }

  /* ---- Two-up grid (photo/orbit + text) ---- */
  .gap-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: var(--space-5); align-items: center; }
  .gap-grid > div:last-child { max-width: 52ch; }

  /* ---- Orbit ---- */
  .orbit { position: relative; width: min(360px, 92%); aspect-ratio: 1; margin-inline: auto; }
  .orbit__me {
    position: absolute; inset: 12%; width: 76%; height: 76%; object-fit: cover; border-radius: 50%;
    -webkit-mask-image: radial-gradient(closest-side, #000 78%, transparent 100%);
    mask-image: radial-gradient(closest-side, #000 78%, transparent 100%);
    box-shadow: var(--shadow-card);
  }
  .float {
    position: absolute; white-space: nowrap; z-index: 3;
    font-family: var(--font-sub); font-weight: 800; font-style: italic; font-size: var(--text-sm);
    background: var(--cream); color: var(--rust); padding: 0.32rem 0.7rem; border-radius: 999px;
    box-shadow: var(--shadow-card); animation: floatA 6s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * -0.8s);
  }
  .orbit .float:nth-child(2) { top: -3%; left: 4%; }
  .orbit .float:nth-child(3) { top: 6%; right: -4%; }
  .orbit .float:nth-child(4) { top: 34%; left: -14%; }
  .orbit .float:nth-child(5) { top: 30%; right: -14%; }
  .orbit .float:nth-child(6) { bottom: 26%; left: -10%; }
  .orbit .float:nth-child(7) { bottom: 8%; right: -6%; }
  .orbit .float:nth-child(8) { bottom: -4%; left: 30%; }
  .float--1 { animation-name: floatB; }
  .float--2 { animation-name: floatC; }
  .float--3 { animation-name: floatA; animation-duration: 7.5s; }
  .orbit--life .float { color: var(--olive); font-size: 0.95rem; }

  /* ---- Thought bubbles (the gap I live in) ---- */
  .thoughts { position: relative; width: min(460px, 100%); aspect-ratio: 1 / 1; margin-inline: auto; }
  .thought {
    position: absolute; white-space: nowrap; z-index: 2; background: var(--bub);
    font-family: var(--font-sub); font-weight: 800; font-style: italic; font-size: 1.1rem;
    padding: 0.85rem 1.4rem; border-radius: 2rem; box-shadow: var(--shadow-card);
    animation: floatA 6s ease-in-out infinite; animation-delay: calc(var(--i, 0) * -0.7s);
  }
  /* two trailing thought dots, the bubble colour */
  .thought::before, .thought::after { content: ''; position: absolute; border-radius: 50%; background: var(--bub); }
  .thought::before { width: 14px; height: 14px; bottom: -11px; left: 18px; }
  .thought::after { width: 9px; height: 9px; bottom: -23px; left: 10px; }
  .thought--0 { --bub: var(--rust); color: var(--cream); }
  .thought--1 { --bub: var(--olive); color: var(--cream); animation-name: floatB; }
  .thought--2 { --bub: var(--blue); color: var(--brown); }
  .thought--3 { --bub: var(--peach); color: var(--brown); animation-name: floatC; }
  .thought--4 { --bub: var(--forest); color: var(--cream); }
  .thought--5 { --bub: var(--brown); color: var(--cream); animation-name: floatB; }
  .thought:nth-child(1) { top: 2%; left: 0%; }
  .thought:nth-child(2) { top: 1%; left: 50%; }
  .thought:nth-child(3) { top: 24%; left: 16%; z-index: 3; }
  .thought:nth-child(4) { top: 30%; left: 54%; }
  .thought:nth-child(5) { top: 50%; left: 2%; }
  .thought:nth-child(6) { top: 54%; left: 44%; z-index: 3; }
  .thought:nth-child(7) { top: 75%; left: 22%; }

  @keyframes floatA { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-12px) } }
  @keyframes floatB { 0%,100% { transform: translate(0,0) } 50% { transform: translate(7px, 9px) } }
  @keyframes floatC { 0%,100% { transform: translate(0,0) rotate(-3deg) } 50% { transform: translate(-8px,-7px) rotate(3deg) } }

  /* ---- Both sides + industries line (forest) ---- */
  .sides { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); margin-top: var(--space-4); }
  .side { background: var(--cream); color: var(--brown); border-radius: 16px; padding: var(--space-3); box-shadow: var(--shadow-card); }
  .side svg { width: 38px; height: 38px; color: var(--rust); }
  .side h3 { margin: var(--space-1) 0 0.2rem; color: var(--rust); }
  .side p { margin: 0; font-size: var(--text-sm); }
  .rooms-line { margin: var(--space-4) 0 0; font-family: var(--font-sub); font-style: italic; font-weight: 800; font-size: var(--text-lg); color: var(--cream); line-height: 1.5; }
  .rooms-line__cap { color: var(--peach); margin-right: 0.4rem; }
  .rooms-line .dot { color: rgba(252,245,229,0.45); }

  /* ---- Playbook: balanced half of the section, blended in ---- */
  .how-band { position: relative; overflow: hidden; }
  .how-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); align-items: center; }
  .how-grid .measure { max-width: 42rem; }
  .playbook { position: relative; margin: 0;
    -webkit-mask-image: radial-gradient(140% 130% at 60% 55%, #000 60%, transparent 96%);
    mask-image: radial-gradient(140% 130% at 60% 55%, #000 60%, transparent 96%); }
  .playbook svg { width: 100%; height: auto; display: block; }
  .playbook__tag { position: absolute; top: -8px; left: 4%; font-family: var(--font-sub); font-weight: 800; font-style: italic; color: var(--brown); font-size: var(--text-sm); opacity: 0.75; }

  /* ---- FAQ + sticker stack ---- */
  .faq-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: var(--space-5); align-items: center; }
  .faq { display: grid; gap: var(--space-3); margin: 0; }
  .faq__item { border-left: 3px solid var(--rust); padding-left: var(--space-2); }
  .faq dt { font-family: var(--font-heading); font-size: var(--text-lg); color: var(--brown); margin-bottom: 0.3rem; }
  .faq dd { margin: 0; max-width: 56ch; }
  .stickers { position: relative; height: 340px; }
  .stickers__pattern {
    position: absolute; inset: 8% 6%; border-radius: 24px; transform: rotate(-3deg);
    background: linear-gradient(rgba(252,245,229,0.55), rgba(252,245,229,0.55)), url('/brand/patterns/pattern-peach.jpg') center / 220px repeat;
    box-shadow: var(--shadow-card);
  }
  .stk { position: absolute; width: 138px; height: auto; filter: drop-shadow(0 6px 12px rgba(58,42,30,0.22)); will-change: transform; }
  .stk--1 { top: 4%; left: 10%; width: 150px; z-index: 4; }
  .stk--2 { top: 30%; left: 46%; z-index: 3; }
  .stk--3 { top: 2%; left: 50%; width: 150px; z-index: 5; }
  .stk--4 { top: 52%; left: 16%; width: 126px; z-index: 2; }

  .about-ctas { display: flex; flex-wrap: wrap; gap: var(--space-1); justify-content: center; }

  @media (prefers-reduced-motion: reduce) { .float, .thought { animation: none; } }
  @media (max-width: 900px) {
    .how-grid { grid-template-columns: 1fr; gap: var(--space-3); }
    .playbook { max-width: 420px; margin-inline: auto; }
  }
  @media (max-width: 860px) {
    .ahero { grid-template-columns: 1fr; min-height: 0; }
    .ahero__photo { height: 42vh; order: -1; }
    .ahero__photo img { -webkit-mask-image: linear-gradient(0deg, transparent 0, #000 28%); mask-image: linear-gradient(0deg, transparent 0, #000 28%); }
    .faq-grid { grid-template-columns: 1fr; }
    .stickers { height: 280px; max-width: 380px; margin-inline: auto; }
  }
  @media (max-width: 760px) {
    .gap-grid { grid-template-columns: 1fr; }
    .gap-grid--rev .orbit { order: -1; }
    .sides { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Stickers drift gently with scroll (subtle parallax), not a constant loop.
  const stks = Array.from(document.querySelectorAll<HTMLElement>('[data-stk]'));
  if (stks.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const onScroll = () => {
      const vh = window.innerHeight;
      stks.forEach((s) => {
        const rect = s.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const prog = (vh / 2 - center) / vh; // ~ -0.6..0.6
        const rot = Number(s.dataset.rot || 0);
        const depth = Number(s.dataset.depth || 20);
        s.style.transform = `translateY(${(prog * depth).toFixed(1)}px) rotate(${rot}deg)`;
      });
    };
    onScroll();
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { onScroll(); ticking = false; });
    }, { passive: true });
  }
</script>
